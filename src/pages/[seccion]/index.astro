---
// src/pages/[seccion]/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { SECCION_QUERY } from '../../lib/queries';
import type { Articulo } from '../../types/article';

export async function getStaticPaths() {
  const secciones = [
    'sociedad','deportes','salud','educacion','seguridad',
    'cultura','economia','vecinos','politica','opiniones','breves'
  ];
  return secciones.map(seccion => ({ params: { seccion } }));
}

const { seccion } = Astro.params;

const nombres: Record<string, string> = {
  sociedad:  'Sociedad',  deportes:  'Deportes', salud:     'Salud',
  educacion: 'Educación', seguridad: 'Seguridad', cultura:  'Cultura',
  economia:  'Economía',  vecinos:   'Vecinos',   politica: 'Política',
  opiniones: 'Opiniones', breves:    'Breves',
};

const descripciones: Record<string, string> = {
  sociedad:  'Historias, personas y comunidad del Partido de San Martín.',
  deportes:  'Fútbol, básquet y todas las disciplinas del partido.',
  salud:     'Salud pública, centros médicos y campañas en el municipio.',
  educacion: 'Escuelas, universidades y capacitaciones en San Martín.',
  seguridad: 'Seguridad vecinal, comisarías y prevención en el partido.',
  cultura:   'Arte, música, teatro y patrimonio cultural de San Martín.',
  economia:  'Comercio, PyMEs y actividad económica local.',
  vecinos:   'Reclamos, iniciativas y protagonistas del barrio.',
  politica:  'Gestión municipal, concejo deliberante y política local.',
  opiniones: 'Columnas, cartas de lectores y perspectivas del barrio.',
  breves:    'Noticias cortas y urgentes del Partido de San Martín.',
};

// Mapeamos el slug sin tilde a la categoría en mayúsculas con tilde que usa Sanity
const categoriaMap: Record<string, string> = {
  sociedad:  'SOCIEDAD',  deportes:  'DEPORTES', salud:     'SALUD',
  educacion: 'EDUCACIÓN', seguridad: 'SEGURIDAD', cultura:  'CULTURA',
  economia:  'ECONOMÍA',  vecinos:   'VECINOS',   politica: 'POLÍTICA',
  opiniones: 'OPINIONES', breves:    'BREVES',
};

const nombreSeccion  = nombres[seccion]      ?? seccion;
const descripcionSec = descripciones[seccion] ?? `Noticias de ${nombreSeccion} en San Martín`;
// categoriaQuery: valor en mayúsculas con tilde, como está almacenado en Sanity
const categoriaQuery = categoriaMap[seccion]  ?? seccion.toUpperCase();

// SECCION_QUERY usa upper(categoria) == $seccion para comparar en mayúsculas
// (fix: antes se usaba lower() pero se pasaba el valor en mayúsculas → 0 resultados)
let notas: Articulo[] = [];
try {
  notas = await sanityClient.fetch(SECCION_QUERY, { seccion: categoriaQuery });
} catch (e) {
  console.warn(`[seccion/${seccion}] No se pudo obtener notas:`, e);
}

function formatearFecha(iso: string): string {
  return new Date(iso).toLocaleDateString('es-AR', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}
---

<BaseLayout
  title={nombreSeccion}
  description={`Noticias de ${nombreSeccion} en San Martín y Villa Ballester`}
>

<!-- 1. CABECERA DE SECCIÓN -->
<div style="background-color:#1C1C1C;margin-left:calc(-50vw + 50%);margin-right:calc(-50vw + 50%);">
  <div style="max-width:80rem;margin-inline:auto;padding-inline:1rem;padding-block:2.5rem;text-align:center;">
    <p style="font-family:var(--font-cuerpo);font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:rgba(245,245,240,0.55);margin-bottom:0.75rem;">Sección</p>
    <h1 style="font-family:var(--font-titular);font-weight:700;font-size:clamp(2rem,6vw,2.75rem);color:#F5F5F0;line-height:1.1;margin-bottom:0;">{nombreSeccion}</h1>
    <div style="width:3rem;border-top:2px solid #F5F5F0;margin-inline:auto;margin-top:1rem;margin-bottom:1rem;opacity:0.6;"></div>
    <p style="font-family:var(--font-cuerpo);font-size:0.9rem;color:rgba(245,245,240,0.7);max-width:36rem;margin-inline:auto;">{descripcionSec}</p>
  </div>
</div>

<!-- 2. GRILLA DE NOTICIAS -->
<div style="margin-top:2.5rem;">
  <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.75rem;">
    <div style="flex:1;border-top:1px solid var(--color-borde);"></div>
    <span style="font-family:var(--font-cuerpo);font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:var(--color-secundario);white-space:nowrap;">Todas las noticias</span>
    <div style="flex:1;border-top:1px solid var(--color-borde);"></div>
  </div>

  {notas.length > 0 ? (
    <div class="seccion-grid">
      {notas.map((nota) => {
        const imgUrl = nota.imagen
          ? urlFor(nota.imagen).width(800).height(450).url()
          : `https://picsum.photos/seed/${nota.slug.current}/800/450`;
        return (
          <article style="display:flex;flex-direction:column;gap:0.6rem;">
            <a href={`/nota/${nota.slug.current}`} style="display:block;overflow:hidden;">
              <img src={imgUrl} alt={nota.titulo} loading="lazy"
                   style="width:100%;aspect-ratio:16/9;object-fit:cover;transition:transform 0.3s ease;"
                   onmouseover="this.style.transform='scale(1.03)'"
                   onmouseout="this.style.transform='scale(1)'" />
            </a>
            <span style="display:inline-block;align-self:flex-start;font-family:var(--font-cuerpo);font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;background-color:#111;color:#fff;padding:0.2rem 0.5rem;">
              {nota.categoria}
            </span>
            <h2 style="font-family:var(--font-titular);font-size:1.05rem;font-weight:600;line-height:1.35;color:var(--color-periodico);margin:0;">
              <a href={`/nota/${nota.slug.current}`} style="text-decoration:none;color:inherit;"
                 onmouseover="this.style.textDecoration='underline'"
                 onmouseout="this.style.textDecoration='none'">{nota.titulo}</a>
            </h2>
            <p class="bajada-clamp" style="font-family:var(--font-cuerpo);font-size:0.875rem;color:var(--color-secundario);line-height:1.5;margin:0;">
              {nota.bajada}
            </p>
            <span style="font-family:var(--font-cuerpo);font-size:0.72rem;color:var(--color-secundario);">
              {formatearFecha(nota.fechaPublicacion)}
            </span>
          </article>
        );
      })}
    </div>
  ) : (
    <div style="text-align:center;padding:4rem 1rem;">
      <p style="font-family:var(--font-titular);font-size:1.25rem;color:var(--color-periodico);margin-bottom:0.75rem;">
        Todavía no hay noticias en esta sección.
      </p>
      <p style="font-family:var(--font-cuerpo);font-size:0.95rem;color:var(--color-secundario);margin-bottom:1.75rem;">
        Volvé pronto o explorá otras secciones.
      </p>
      <a href="/"
         style="display:inline-block;font-family:var(--font-cuerpo);font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;background-color:#111;color:#fff;padding:0.65rem 1.5rem;text-decoration:none;"
         onmouseover="this.style.backgroundColor='#333'"
         onmouseout="this.style.backgroundColor='#111'">← Volver al inicio</a>
    </div>
  )}
</div>


<!-- 3. PAGINACIÓN PLACEHOLDER -->
{notas.length > 0 && (
  <div style="display:flex;align-items:center;justify-content:center;gap:1rem;margin-top:3rem;margin-bottom:1.5rem;">
    <button disabled aria-disabled="true"
            style="font-family:var(--font-cuerpo);font-size:0.8rem;font-weight:600;border:1px solid #1C1C1C;padding:0.5rem 1.1rem;background:transparent;color:var(--color-periodico);cursor:not-allowed;opacity:0.4;">
      &larr; Anterior
    </button>
    <span style="font-family:var(--font-cuerpo);font-size:0.8rem;color:var(--color-secundario);padding-inline:0.5rem;">
      Página 1 de 1
    </span>
    <button disabled aria-disabled="true"
            style="font-family:var(--font-cuerpo);font-size:0.8rem;font-weight:600;border:1px solid #1C1C1C;padding:0.5rem 1.1rem;background:transparent;color:var(--color-periodico);cursor:not-allowed;opacity:0.4;">
      Siguiente &rarr;
    </button>
  </div>
)}

</BaseLayout>

<style>
  .seccion-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 640px)  { .seccion-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .seccion-grid { grid-template-columns: repeat(3, 1fr); } }

  .bajada-clamp {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
