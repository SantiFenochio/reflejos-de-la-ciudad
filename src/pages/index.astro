---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../lib/sanity';
import { HOME_QUERY } from '../lib/queries';
import type { Articulo } from '../types/article';
import Publicidad from '../components/ui/Publicidad.astro';

// Noticias: hero + hasta 9 cards en grilla (para dar lugar a intercalados)
let notas: Articulo[] = [];
try {
  notas = await sanityClient.fetch(HOME_QUERY);
} catch (e) {
  console.warn('[index] No se pudo obtener notas:', e);
}

// Publicidades: todas activas, ordenadas por campo "orden" asc
let publicidades: any[] = [];
try {
  publicidades = await sanityClient.fetch(
    `*[_type == "publicidad" && activa == true] | order(orden asc) {
      _id, nombre, linkDestino, posicion,
      "imagenUrl": imagen.asset->url
    }`
  );
} catch (e) {
  console.warn('[index] No se pudo obtener publicidades:', e);
}

const hero             = notas[0] ?? null;
const notasSecundarias = notas.slice(1, 3);   // Las 2 siguientes para el panel derecho del hero
const grilla           = notas.slice(3, 13);  // Arranca en 3 para no repetir las del hero
const carrusel         = grilla;

function formatearFecha(iso: string): string {
  return new Date(iso).toLocaleDateString('es-AR', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}

const heroImg = hero?.imagen
  ? urlFor(hero.imagen).width(900).height(506).fit('crop').format('webp').url()
  : 'https://picsum.photos/seed/hero-rdlc/1400/620';


---

<BaseLayout
  title="Reflejos de la Ciudad — Noticias de San Martín y Villa Ballester"
  description="Diario digital local de General San Martín y Villa Ballester, Buenos Aires. Noticias de política, cultura, deportes, vecinos y más."
  image="/Logo.png"
>

<!-- ============================================================
     HERO — nota destacada
     ============================================================ -->
<section class="hero-section">
  <div class="hero-grid">

    <!-- ── IZQUIERDA: nota principal (≈65%) ── -->
    <div class="hero-izq">
      {hero ? (
        <div class="hero-wrap">
          <img src={heroImg} alt={hero.titulo} class="hero-img" loading="eager" />
          <div class="hero-overlay"></div>
          <div class="hero-content">
            {hero.categoria && <span class="badge-rojo">{hero.categoria}</span>}
            <a href={`/nota/${hero.slug.current}`} class="hero-link">
              <h1 class="hero-titulo">{hero.titulo}</h1>
              {hero.bajada && <p class="hero-bajada">{hero.bajada}</p>}
            </a>
            <p class="hero-meta">
              {hero.autor && <span>Por {hero.autor}</span>}
              {hero.autor && <span class="hero-sep" aria-hidden="true">&middot;</span>}
              <span>{formatearFecha(hero.fechaPublicacion)}</span>
            </p>
          </div>
        </div>
      ) : (
        <div class="hero-vacio">
          <p style="font-family:var(--font-cuerpo);color:#666;font-size:1rem;text-align:center;">
            Publica tu primera nota en Sanity para verla aqui
          </p>
        </div>
      )}
    </div>

    <!-- ── DERECHA: 2 notas secundarias apiladas (≈35%) ── -->
    {notasSecundarias.length > 0 && (
      <div class="hero-der">
        {notasSecundarias.map((nota) => {
          const imgSec = nota.imagen
            ? urlFor(nota.imagen).width(600).height(450).fit('crop').format('webp').url()
            : `https://picsum.photos/seed/sec-${nota.slug.current}/640/360`;
          return (
            <article class="card-sec">
              <a href={`/nota/${nota.slug.current}`} class="card-sec-img-wrap">
                <img src={imgSec} alt={nota.titulo} loading="eager" class="card-sec-img" />
                {nota.categoria && <span class="badge-rojo badge-sm badge-sobre-img">{nota.categoria}</span>}
              </a>
              <div class="card-sec-body">
                <h2 class="card-sec-titulo">
                  <a href={`/nota/${nota.slug.current}`} class="card-sec-titulo-lnk">{nota.titulo}</a>
                </h2>
                <p class="card-sec-meta">{formatearFecha(nota.fechaPublicacion)}</p>
              </div>
            </article>
          );
        })}
      </div>
    )}

  </div>
</section>

<!-- Separador triple estilo diario -->
<div class="separador-triple">
  <div class="sep-linea"></div>
  <div class="sep-linea gruesa"></div>
  <div class="sep-linea"></div>
</div>

<!-- ============================================================
     CARRUSEL DE DESTACADAS
     CSS scroll-snap + flechas + dots + autoscroll JS vanilla
     ============================================================ -->
{carrusel.length > 0 && (
  <section class="car-section">
    <div class="sec-header">
      <span class="sec-barra-roja"></span>
      <h2 class="sec-titulo">Destacadas</h2>
      <div class="sec-linea"></div>
    </div>

    <div class="car-outer">
      <!-- Flecha izquierda -->
      <button class="car-btn car-prev" id="car-prev" aria-label="Nota anterior">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <!-- Track con scroll-snap -->
      <div class="car-track" id="car-track">
        {carrusel.map((nota, i) => {
          const imgUrl = nota.imagen
            ? urlFor(nota.imagen).width(600).height(400).fit('crop').format('webp').url()
            : `https://picsum.photos/seed/car-${nota.slug.current}/600/340`;
          return (
            <div class="car-slide" data-index={i}>
              <a href={`/nota/${nota.slug.current}`} class="car-img-wrap">
                <img src={imgUrl} alt={nota.titulo} loading="lazy" class="car-img" />
              </a>
              <div class="car-body">
                {nota.categoria && <span class="badge-rojo badge-sm">{nota.categoria}</span>}
                <h3 class="car-titulo">
                  <a href={`/nota/${nota.slug.current}`} class="car-titulo-lnk">{nota.titulo}</a>
                </h3>
                <p class="car-meta">{formatearFecha(nota.fechaPublicacion)}</p>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Flecha derecha -->
      <button class="car-btn car-next" id="car-next" aria-label="Nota siguiente">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <!-- Dots de navegacion -->
    <div class="car-dots" id="car-dots" role="tablist">
      {carrusel.map((_, i) => (
        <button
          class={`car-dot${i === 0 ? ' active' : ''}`}
          data-index={i}
          aria-label={`Ir a nota ${i + 1}`}
          role="tab"
        ></button>
      ))}
    </div>
  </section>
)}

<!-- ============================================================
     CUERPO: GRILLA DE NOTICIAS + SIDEBAR
     ============================================================ -->
<div class="cuerpo-grid">

  <!-- COLUMNA PRINCIPAL: noticias + cargar más -->
  <div class="col-principal">
    <section>
      <div class="sec-header">
        <span class="sec-barra-roja"></span>
        <h2 class="sec-titulo">Ultimas Noticias</h2>
        <div class="sec-linea"></div>
      </div>

      {grilla.length > 0 ? (
        <div class="notas-grid">
          {grilla.map((nota, i) => {
            const imgUrl = nota.imagen
              ? urlFor(nota.imagen).width(600).height(400).fit('crop').format('webp').url()
              : `https://picsum.photos/seed/${nota.slug.current}/800/450`;
            const mostrarPubMobile = i === 2 && publicidades.length > 0;
            return (
              <Fragment>
                <article class="card animar">
                  <a href={`/nota/${nota.slug.current}`} class="card-img-wrap">
                    <img src={imgUrl} alt={nota.titulo} loading="lazy" class="card-img" />
                    {nota.categoria && <span class="badge-rojo badge-sm badge-sobre-img">{nota.categoria}</span>}
                  </a>
                  <div class="card-body">
                    <h2 class="card-titulo">
                      <a href={`/nota/${nota.slug.current}`} class="card-titulo-lnk">{nota.titulo}</a>
                    </h2>
                    {nota.bajada && <p class="card-bajada">{nota.bajada}</p>}
                    <p class="card-meta">
                      {nota.autor && <span>Por {nota.autor}</span>}
                      {nota.autor && <span aria-hidden="true"> &middot; </span>}
                      <span>{formatearFecha(nota.fechaPublicacion)}</span>
                    </p>
                  </div>
                </article>
                {mostrarPubMobile && (
                  <div class="pub-mobile-solo">
                    <p class="pub-mobile-label">Publicidad</p>
                    <Publicidad pub={publicidades[0]} />
                  </div>
                )}
              </Fragment>
            );
          })}
        </div>
      ) : (
        <p class="empty-msg">Proximamente mas noticias.</p>
      )}
    </section>

    <!-- CARGAR MÁS — dentro de la columna principal -->
    <div id="cargar-mas-wrap" style="text-align:center;margin-top:2rem;">
      <button id="btn-cargar-mas" class="btn-cargar-mas" data-offset="13">
        Cargar más noticias
      </button>
      <p id="cargar-mas-fin" class="cargar-mas-fin" hidden>No hay más noticias.</p>
    </div>
  </div>{/* fin col-principal */}

  <!-- SIDEBAR: Publicidades primero, luego redes -->
  <aside class="sidebar">

    <!-- Publicidades: TODAS las activas ordenadas por campo "orden" — al tope para máxima visibilidad -->
    {publicidades.length > 0 ? (
      <div class="pubs-wrap">
        <p class="pubs-label">Publicidad</p>
        {publicidades.map((pub: any) => (
          <Publicidad pub={pub} />
        ))}
      </div>
    ) : (
      <div class="pub-box">
        <p class="pub-label">Espacio Publicitario</p>
        <p class="pub-nombre">Anuncia en Reflejos</p>
        <p class="pub-desc">Llega a toda la comunidad de San Martin y sus alrededores</p>
        <a href="mailto:redaccion@reflejosdelaciudad.com.ar" class="pub-btn">Consultanos</a>
      </div>
    )}


  </aside>

</div>{/* fin cuerpo-grid */}

</BaseLayout>

<style>
  /* HERO */
  .hero-section { margin: -1.5rem -1rem 0; }

  /* Grid 2 columnas en desktop, 1 en mobile */
  .hero-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    align-items: stretch;
    min-height: 480px;
    gap: 16px;
  }
  @media (min-width: 1024px) { .hero-grid { min-height: 560px; } }
  @media (max-width: 767px)  { .hero-grid { grid-template-columns: 1fr; min-height: auto; } }

  .hero-izq { position: relative; }

  /* Panel derecho: dos tarjetas apiladas con separador */
  .hero-der {
    display: flex; flex-direction: column;
    gap: 12px;
    border-left: 1px solid #D0D0D0;
    background: #fff;
  }
  @media (max-width: 767px) { .hero-der { border-left: none; border-top: 2px solid #1C1C1C; } }

  /* Tarjetas secundarias */
  .card-sec { display: flex; flex-direction: column; flex: 1; transition: background 0.15s; }
  .card-sec:not(:last-child) { border-bottom: 1px solid #D0D0D0; }
  .card-sec:hover { background: #F9F9F7; }
  .card-sec-img-wrap {
    display: block; overflow: hidden; position: relative;
    aspect-ratio: 4/3; background: #e5e5e5; flex-shrink: 0;
  }
  .card-sec-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .card-sec-img-wrap:hover .card-sec-img { transform: scale(1.05); }
  .card-sec-body { padding: 0.85rem 1rem; display: flex; flex-direction: column; flex: 1; }
  .card-sec-titulo {
    font-family: var(--font-titular);
    font-size: clamp(0.9rem, 1.3vw, 1.1rem); font-weight: 700;
    line-height: 1.3; color: #1C1C1C; margin: 0.2rem 0 0.4rem;
  }
  .card-sec-titulo-lnk { color: inherit; text-decoration: none; transition: color 0.15s; }
  .card-sec-titulo-lnk:hover { color: #4c6a92; }
  .card-sec-meta { font-family: var(--font-cuerpo); font-size: 0.68rem; color: #999; margin: auto 0 0; }

  /* Hero wrap: ocupa el 100% de la celda izquierda del grid */
  .hero-wrap {
    position: relative; width: 100%; height: 100%;
    min-height: 300px;
    overflow: hidden; background: #1a1a1a;
  }
  @media (min-width: 640px)  { .hero-wrap { min-height: 420px; } }
  @media (max-width: 767px)  { .hero-wrap { height: 300px; } }
  .hero-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
    transition: transform 0.7s ease;
  }
  .hero-wrap:hover .hero-img { transform: scale(1.03); }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.5) 45%, transparent 100%);
  }
  .hero-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 1.5rem 1.25rem; max-width: 1280px;
  }
  @media (min-width: 768px) { .hero-content { padding: 2.5rem 2rem; } }
  .hero-link { display: block; text-decoration: none; }
  .hero-link:hover .hero-titulo { text-decoration: underline; text-underline-offset: 4px; }
  .hero-titulo {
    font-family: var(--font-titular);
    font-size: clamp(1.4rem, 3.5vw, 2.6rem); font-weight: 700; line-height: 1.12;
    color: #fff; margin: 0.5rem 0 0.65rem; max-width: 46rem;
    text-shadow: 0 1px 4px rgba(0,0,0,0.35);
    word-break: break-word; overflow-wrap: break-word;
  }
  @media (max-width: 480px) {
    .hero-titulo { font-size: 1.4rem; }
    .hero-content { padding: 1rem 1rem; }
    .hero-bajada { font-size: 0.875rem; }
  }
  .hero-bajada {
    font-family: var(--font-cuerpo);
    font-size: clamp(0.875rem, 1.2vw, 1rem); color: rgba(255,255,255,0.85);
    max-width: 40rem; line-height: 1.55; margin: 0 0 0.75rem;
  }
  .hero-meta {
    font-family: var(--font-cuerpo); font-size: 0.75rem;
    color: rgba(255,255,255,0.5); margin: 0;
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.1rem;
  }
  .hero-sep { margin: 0 0.3rem; }
  .hero-vacio { height: 300px; background: #ddd; display: flex; align-items: center; justify-content: center; }
</style>

<style>
  /* BADGES */
  .badge-rojo {
    display: inline-block; background: #4c6a92; color: #fff;
    font-family: var(--font-cuerpo); font-size: 0.63rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    padding: 0.25rem 0.65rem; margin-bottom: 0.5rem;
  }
  .badge-sm { font-size: 0.58rem; padding: 0.2rem 0.5rem; margin-bottom: 0.4rem; }

  /* SEPARADOR TRIPLE */
  .separador-triple { display: flex; flex-direction: column; gap: 3px; margin: 1.75rem 0 2rem; }
  .sep-linea { border-top: 1px solid #1a1a1a; }
  .sep-linea.gruesa { border-top-width: 3px; }

  /* ENCABEZADO DE SECCION */
  .sec-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; }
  .sec-barra-roja { display: inline-block; width: 4px; height: 1.3rem; background: #4c6a92; flex-shrink: 0; }
  .sec-titulo {
    font-family: var(--font-cuerpo); font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.2em; color: #1a1a1a; margin: 0;
  }
  .sec-linea { flex: 1; height: 1px; background: #D0D0D0; margin-left: 0.25rem; }

  /* LAYOUT PRINCIPAL: dos columnas fijas */
  .cuerpo-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    align-items: start;
  }
  /* Columna izquierda: noticias + cargar más apilados */
  .col-principal { display: flex; flex-direction: column; min-width: 0; }

  /* Mobile: una sola columna */
  @media (max-width: 768px) {
    .cuerpo-grid { grid-template-columns: 1fr; }
    .sidebar { display: none; } /* ads se muestran inline entre noticias en mobile */
  }

  /* GRILLA DE NOTICIAS */
  .notas-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 640px)  { .notas-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .notas-grid { grid-template-columns: repeat(3, 1fr); } }

  .empty-msg { font-family: var(--font-cuerpo); color: #888; font-size: 0.95rem; padding: 2rem 0; text-align: center; }
</style>

<style>
  /* CARDS */
  .card {
    display: flex; flex-direction: column;
    transition: box-shadow 0.2s ease;
    border-radius: 2px;
  }
  .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.12); }
  .card-img-wrap {
    display: block; overflow: hidden; position: relative;
    aspect-ratio: 3/2; background: #e5e5e5; margin-bottom: 0.75rem;
  }
  .card-img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.4s ease;
  }
  .card-img-wrap:hover .card-img { transform: scale(1.06); }
  /* Badge flotante sobre la imagen */
  .badge-sobre-img {
    position: absolute; top: 0.5rem; left: 0.5rem;
    margin-bottom: 0;          /* anula el margin del badge normal */
    border-radius: 3px;
    z-index: 2;
    box-shadow: 0 1px 4px rgba(0,0,0,0.25);
  }
  .card-body { display: flex; flex-direction: column; flex: 1; }
  .card-titulo {
    font-family: var(--font-titular); font-size: 1rem;
    font-weight: 700; line-height: 1.32; color: #1a1a1a; margin: 0 0 0.4rem;
  }
  .card-titulo-lnk { color: inherit; text-decoration: none; transition: color 0.2s ease; }
  .card-titulo-lnk:hover { color: #4c6a92; text-decoration: none; }
  .card-bajada {
    font-family: var(--font-cuerpo); font-size: 0.84rem; color: #555;
    line-height: 1.5; margin: 0 0 0.5rem;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .card-meta { font-family: var(--font-cuerpo); font-size: 0.7rem; color: #999; margin: auto 0 0; padding-top: 0.5rem; }
</style>

<style>
  /* SIDEBAR */
  .sidebar {
    position: sticky;
    top: 80px;
    align-self: start;
    border-left: 1px solid #D0D0D0;
    padding-left: 1.5rem;
  }
  @media (max-width: 768px) {
    .sidebar {
      border-left: none;
      border-top: 3px solid #1a1a1a;
      padding-left: 0;
      padding-top: 1.25rem;
    }
  }
  /* PUBLICIDAD SIDEBAR */
  .pubs-wrap { display: flex; flex-direction: column; gap: 1.5rem; }
  .pubs-label {
    font-family: var(--font-cuerpo);
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #aaa;
    text-align: center;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #D0D0D0;
    margin: 0 0 0.25rem;
  }

  /* PUBLICIDAD MOBILE INLINE — solo visible en mobile, dentro de la grilla */
  .pub-mobile-solo {
    display: none;
    grid-column: 1 / -1;
    border-top: 1px solid #D0D0D0;
    border-bottom: 1px solid #D0D0D0;
    padding: 0.75rem 0;
    background: #F9F9F7;
  }
  .pub-mobile-label {
    font-family: var(--font-cuerpo);
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #aaa;
    text-align: center;
    margin: 0 0 0.5rem;
  }
  @media (max-width: 768px) {
    .pub-mobile-solo { display: block; }
  }

  /* PLACEHOLDER cuando no hay publicidades */
  .pub-box { border: 1px dashed #D0D0D0; background: #F9F9F7; padding: 1.5rem; text-align: center; }
  .pub-label { font-family: var(--font-cuerpo); font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: #aaa; margin: 0 0 0.5rem; }
  .pub-nombre { font-family: var(--font-titular); font-size: 1.2rem; font-weight: 700; color: #1a1a1a; margin: 0 0 0.4rem; line-height: 1.2; }
  .pub-desc { font-family: var(--font-cuerpo); font-size: 0.8rem; color: #666; margin: 0 0 1.25rem; line-height: 1.45; }
  .pub-btn {
    display: block; background: #4c6a92; color: #fff;
    font-family: var(--font-cuerpo); font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    padding: 0.65rem 1rem; text-decoration: none; transition: background-color 0.15s;
  }
  .pub-btn:hover { background: #3b5475; text-decoration: none; }
</style>

<style>
  /* ============================================================
     CARRUSEL
     ============================================================ */
  .car-section { margin-bottom: 2.5rem; }

  .car-outer {
    position: relative;
    display: flex; align-items: center; gap: 0.5rem;
  }

  /* Track con scroll-snap horizontal */
  .car-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    gap: 1.25rem;
    flex: 1;
    padding-bottom: 0.25rem; /* espacio para el shadow de hover */
  }
  .car-track::-webkit-scrollbar { display: none; }
  .car-track { scrollbar-width: none; }

  /* Slides: 1 en mobile, 2 en tablet, 3 en desktop */
  .car-slide {
    scroll-snap-align: start;
    flex-shrink: 0;            /* nunca encoge — evita el whitespace fantasma */
    width: 80%;                /* mobile: 1 slide visible + peek del siguiente */
    display: flex; flex-direction: column;
  }
  @media (min-width: 640px)  { .car-slide { width: calc(50% - 0.625rem); } }
  @media (min-width: 1024px) { .car-slide { width: calc(33.333% - 0.834rem); } }

  /* Imagen del slide */
  .car-img-wrap {
    display: block; overflow: hidden;
    aspect-ratio: 3/2; background: #e5e5e5; margin-bottom: 0.65rem;
  }
  .car-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .car-img-wrap:hover .car-img { transform: scale(1.06); }

  /* Body del slide */
  .car-body { display: flex; flex-direction: column; }
  .car-titulo {
    font-family: var(--font-titular); font-size: 0.95rem;
    font-weight: 700; line-height: 1.3; color: #1a1a1a; margin: 0 0 0.35rem;
  }
  .car-titulo-lnk { color: inherit; text-decoration: none; transition: color 0.2s ease; }
  .car-titulo-lnk:hover { color: #4c6a92; text-decoration: none; }
  .car-meta { font-family: var(--font-cuerpo); font-size: 0.68rem; color: #999; margin: 0; }

  /* Flechas */
  .car-btn {
    flex-shrink: 0; width: 34px; height: 34px;
    background: #1a1a1a; color: #fff; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background-color 0.15s;
    border-radius: 2px;
  }
  .car-btn:hover { background: #4c6a92; }
  /* Ocultar flechas en mobile para no molestar el scroll tactil */
  @media (max-width: 639px) { .car-btn { display: none; } }

  /* Dots */
  .car-dots {
    display: flex; justify-content: center; gap: 0.5rem;
    margin-top: 1rem;
  }
  .car-dot {
    width: 8px; height: 8px;
    border-radius: 50%; border: none; cursor: pointer;
    background: #D0D0D0; padding: 0;
    transition: background-color 0.2s, transform 0.2s;
  }
  .car-dot.active { background: #4c6a92; transform: scale(1.3); }
</style>

<style>
  /* ============================================================
     ANIMACIONES DE ENTRADA (Intersection Observer)
     ============================================================ */
  .animar {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .animar.visible {
    opacity: 1;
    transform: translateY(0);
  }
  /* Stagger: cada item se retrasa levemente segun su posicion */
  .animar:nth-child(2) { transition-delay: 0.06s; }
  .animar:nth-child(3) { transition-delay: 0.12s; }
  .animar:nth-child(4) { transition-delay: 0.06s; }
  .animar:nth-child(5) { transition-delay: 0.12s; }
  .animar:nth-child(6) { transition-delay: 0.18s; }
</style>

<script>
  /* ============================================================
     CARRUSEL — scroll-snap + flechas + dots + autoplay 4s
     ============================================================ */
  (function () {
    var track  = document.getElementById('car-track');
    var dotsEl = document.getElementById('car-dots');
    if (!track) return;

    var slides = Array.from(track.querySelectorAll('.car-slide'));
    var dots   = dotsEl ? Array.from(dotsEl.querySelectorAll('.car-dot')) : [];
    var current = 0;
    var timer;

    function setActive(idx) {
      current = ((idx % slides.length) + slides.length) % slides.length;
      // Scroll al slide target usando offsetLeft para maximo soporte
      track.scrollTo({ left: slides[current].offsetLeft, behavior: 'smooth' });
      dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
    }

    // Sincronizar dots con scroll tactil (mobile)
    var scrollTimer;
    track.addEventListener('scroll', function () {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function () {
        var best = 0; var bestDist = Infinity;
        slides.forEach(function (s, i) {
          var d = Math.abs(s.offsetLeft - track.scrollLeft);
          if (d < bestDist) { bestDist = d; best = i; }
        });
        if (best !== current) {
          current = best;
          dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
        }
      }, 80);
    }, { passive: true });

    // Flechas
    var btnPrev = document.getElementById('car-prev');
    var btnNext = document.getElementById('car-next');
    if (btnPrev) btnPrev.addEventListener('click', function () { clearInterval(timer); setActive(current - 1); startAuto(); });
    if (btnNext) btnNext.addEventListener('click', function () { clearInterval(timer); setActive(current + 1); startAuto(); });

    // Dots
    dots.forEach(function (d, i) {
      d.addEventListener('click', function () { clearInterval(timer); setActive(i); startAuto(); });
    });

    // Autoplay cada 4 segundos
    function startAuto() { timer = setInterval(function () { setActive(current + 1); }, 4000); }

    // Pausar autoplay cuando el usuario interactua con el track
    track.addEventListener('pointerdown', function () { clearInterval(timer); }, { passive: true });
    track.addEventListener('pointerup',   function () { startAuto(); }, { passive: true });

    startAuto();
  })();

  /* ============================================================
     ANIMACIONES DE ENTRADA — Intersection Observer
     ============================================================ */
  (function () {
    var items = document.querySelectorAll('.animar');
    if (!items.length) return;

    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });

    items.forEach(function (el) { obs.observe(el); });
  })();
</script>

<style>
  /* CARGAR MÁS */
  .btn-cargar-mas {
    background: #4c6a92; color: #fff;
    font-family: var(--font-cuerpo); font-size: 0.78rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.14em;
    border: none; cursor: pointer;
    padding: 0.75rem 2rem;
    transition: background-color 0.15s, transform 0.1s;
  }
  .btn-cargar-mas:hover { background: #3b5475; }
  .btn-cargar-mas:active { transform: scale(0.98); }
  .btn-cargar-mas:disabled { background: #ccc; cursor: not-allowed; }
  .cargar-mas-fin { font-family: var(--font-cuerpo); font-size: 0.82rem; color: #aaa; margin-top: 1rem; }

  /* Animación fade-in para cards nuevas */
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .card-nueva { animation: fadeInUp 0.35s ease both; }
</style>

<script>
(function() {
  var SANITY_PROJECT = 'k3agywgt';
  var SANITY_DATASET = 'production';
  var SANITY_VER     = '2024-01-01';
  var LIMIT = 12;

  var btnCargar = document.getElementById('btn-cargar-mas');
  var finMsg    = document.getElementById('cargar-mas-fin');
  var notasGrid = document.querySelector('.notas-grid');

  if (!btnCargar || !notasGrid) return;

  function formatFecha(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function crearCard(nota) {
    var imgUrl = nota.imgUrl
      ? nota.imgUrl + '?w=800&h=450&fit=crop&auto=format'
      : 'https://picsum.photos/seed/' + (nota.slug || 'default') + '/800/450';

    var card = document.createElement('article');
    card.className = 'card animar card-nueva';

    card.innerHTML =
      '<a href="/nota/' + nota.slug + '" class="card-img-wrap">'
      + '<img src="' + imgUrl + '" alt="' + nota.titulo.replace(/"/g,'&quot;') + '" loading="lazy" class="card-img" />'
      + (nota.categoria ? '<span class="badge-rojo badge-sm badge-sobre-img">' + nota.categoria + '</span>' : '')
      + '</a>'
      + '<div class="card-body">'
      + '<h2 class="card-titulo"><a href="/nota/' + nota.slug + '" class="card-titulo-lnk">' + nota.titulo + '</a></h2>'
      + (nota.bajada ? '<p class="card-bajada">' + nota.bajada + '</p>' : '')
      + '<p class="card-meta">'
      + (nota.autor ? 'Por ' + nota.autor + ' &middot; ' : '')
      + formatFecha(nota.fechaPublicacion)
      + '</p>'
      + '</div>';

    return card;
  }

  btnCargar.addEventListener('click', async function() {
    var offset = parseInt(btnCargar.dataset.offset || '13', 10);
    btnCargar.disabled = true;
    btnCargar.textContent = 'Cargando...';

    try {
      var end   = offset + LIMIT - 1;
      var query = '*[_type == "articulo"] | order(fechaPublicacion desc) [' + offset + '...' + (offset + LIMIT) + '] { titulo, "slug": slug.current, bajada, categoria, fechaPublicacion, autor, "imgUrl": imagenPrincipal.asset->url }';
      var url   = 'https://' + SANITY_PROJECT + '.apicdn.sanity.io/v' + SANITY_VER + '/data/query/' + SANITY_DATASET + '?query=' + encodeURIComponent(query);
      var res   = await fetch(url);
      var data  = await res.json();
      var notas = data.result || [];

      notas.forEach(function(nota) {
        notasGrid.appendChild(crearCard(nota));
      });

      if (notas.length < LIMIT) {
        btnCargar.hidden = true;
        if (finMsg) finMsg.hidden = false;
      } else {
        btnCargar.dataset.offset = String(offset + LIMIT);
        btnCargar.disabled = false;
        btnCargar.textContent = 'Cargar más noticias';
      }
    } catch (err) {
      btnCargar.disabled = false;
      btnCargar.textContent = 'Cargar más noticias';
    }
  });
})();
</script>
