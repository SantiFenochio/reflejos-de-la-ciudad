---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../lib/sanity';
import { HOME_QUERY, PUBLICIDADES_QUERY } from '../lib/queries';
import type { Articulo } from '../types/article';
import Publicidad from '../components/ui/Publicidad.astro';

const notas: Articulo[] = await sanityClient.fetch(HOME_QUERY);
const pubsSidebar = await sanityClient.fetch(PUBLICIDADES_QUERY, { posicion: 'sidebar' });

const hero   = notas[0] ?? null;
const grilla = notas.slice(1, 7);

function formatearFecha(iso: string): string {
  return new Date(iso).toLocaleDateString('es-AR', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}

const heroImg = hero?.imagen
  ? urlFor(hero.imagen).width(1200).height(480).url()
  : 'https://picsum.photos/seed/default/1200/480';

const masLeidas = [
  { categoria: 'VECINOS',   titulo: 'No te vuelvas loco llega al Espacio Cultural Ballester',  slug: 'no-te-vuelvas-loco-ballester'     },
  { categoria: 'EDUCACIÓN', titulo: 'Cursos y capacitaciones en la CESAM de San Martín',        slug: 'cursos-cesam-san-martin'          },
  { categoria: 'SOCIEDAD',  titulo: '1er. Congreso de Educación del Partido de San Martín',     slug: 'congreso-educacion-san-martin'    },
  { categoria: 'ECONOMÍA',  titulo: 'Vuelve Expo Ciudad PyME a Villa Ballester',                slug: 'expo-ciudad-pyme-ballester'       },
  { categoria: 'CULTURA',   titulo: 'Muestra fotográfica en el Centro Cultural San Martín',     slug: 'muestra-fotografica-cc-san-martin'},
];
---

<BaseLayout
  title="Portada"
  description="Semanario digital del barrio San Martín, Villa Ballester y alrededores. Buenos Aires, Argentina."
>

<!-- ══════════════════════════════════════════════════════════════
     BLOQUE 1 — NOTA HERO
══════════════════════════════════════════════════════════════════ -->
{hero ? (
  <div class="hero-container relative w-full overflow-hidden">
    <img
      src={heroImg}
      alt={hero.titulo}
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.82) 0%,transparent 100%);"></div>

    <div style="position:absolute;bottom:0;left:0;right:0;padding:1.5rem;max-width:80rem;margin:0 auto;">
      <span style="display:inline-block;font-family:var(--font-cuerpo);font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;background:transparent;border:1px solid rgba(255,255,255,0.7);color:#fff;padding:0.2rem 0.6rem;margin-bottom:0.75rem;">
        {hero.categoria}
      </span>

      <a href={`/nota/${hero.slug.current}`} style="display:block;text-decoration:none;">
        <h1 style="font-family:var(--font-titular);font-size:clamp(1.5rem,4vw,2.75rem);font-weight:700;line-height:1.15;color:#fff;margin-bottom:0.6rem;max-width:48rem;">
          {hero.titulo}
        </h1>
        {hero.bajada && (
          <p style="font-family:var(--font-cuerpo);font-size:1.05rem;color:rgba(255,255,255,0.88);max-width:42rem;margin-bottom:0.75rem;line-height:1.5;">
            {hero.bajada}
          </p>
        )}
      </a>

      <div style="font-family:var(--font-cuerpo);font-size:0.78rem;color:rgba(255,255,255,0.6);display:flex;gap:0.4rem;align-items:center;">
        <span>Por {hero.autor}</span>
        <span aria-hidden="true">&middot;</span>
        <span>{formatearFecha(hero.fechaPublicacion)}</span>
      </div>
    </div>
  </div>
) : (
  <div class="hero-container" style="background:#ccc;display:flex;align-items:center;justify-content:center;">
    <p style="font-family:var(--font-cuerpo);font-size:1.1rem;color:#555;text-align:center;padding:1.5rem;">
      Publicá tu primera nota en Sanity para verla aquí
    </p>
  </div>
)}


<!-- SEPARADOR DOBLE -->
<div style="padding-block:1.25rem;">
  <div style="border-top:3px double #1C1C1C;"></div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     BLOQUE 2 — CUERPO: GRILLA + SIDEBAR
══════════════════════════════════════════════════════════════════ -->
<div class="cuerpo-grid">

  <!-- COLUMNA PRINCIPAL -->
  <div>
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
      <div style="flex:1;border-top:1px solid var(--color-borde);"></div>
      <span style="font-family:var(--font-cuerpo);font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:var(--color-secundario);white-space:nowrap;">Últimas Noticias</span>
      <div style="flex:1;border-top:1px solid var(--color-borde);"></div>
    </div>

    {grilla.length > 0 ? (
      <div class="notas-grid">
        {grilla.map((nota) => {
          const imgUrl = nota.imagen
            ? urlFor(nota.imagen).width(800).height(450).url()
            : `https://picsum.photos/seed/${nota.slug.current}/800/450`;
          return (
            <article style="display:flex;flex-direction:column;gap:0.6rem;">
              <a href={`/nota/${nota.slug.current}`} style="display:block;overflow:hidden;">
                <img
                  src={imgUrl}
                  alt={nota.titulo}
                  loading="lazy"
                  style="width:100%;aspect-ratio:16/9;object-fit:cover;transition:transform 0.3s ease;"
                  onmouseover="this.style.transform='scale(1.03)'"
                  onmouseout="this.style.transform='scale(1)'"
                />
              </a>
              <span style="display:inline-block;align-self:flex-start;font-family:var(--font-cuerpo);font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;background-color:#111;color:#fff;padding:0.2rem 0.5rem;">
                {nota.categoria}
              </span>
              <h2 style="font-family:var(--font-titular);font-size:1rem;font-weight:600;line-height:1.35;color:var(--color-periodico);margin:0;">
                <a href={`/nota/${nota.slug.current}`} style="text-decoration:none;color:inherit;"
                   onmouseover="this.style.textDecoration='underline'"
                   onmouseout="this.style.textDecoration='none'">{nota.titulo}</a>
              </h2>
              <span style="font-family:var(--font-cuerpo);font-size:0.75rem;color:var(--color-secundario);">
                {formatearFecha(nota.fechaPublicacion)}
              </span>
            </article>
          );
        })}
      </div>
    ) : (
      <p style="font-family:var(--font-cuerpo);font-size:0.95rem;color:var(--color-secundario);padding:2rem 0;text-align:center;">
        Próximamente más noticias.
      </p>
    )}
  </div>{/* fin columna principal */}


  <!-- SIDEBAR -->
  <aside style="padding-left:1.5rem;border-left:1px solid var(--color-borde);">

    <div style="margin-bottom:2rem;">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">
        <div style="flex:1;border-top:1px solid var(--color-borde);"></div>
        <span style="font-family:var(--font-cuerpo);font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:var(--color-secundario);white-space:nowrap;">Más Leídas</span>
        <div style="flex:1;border-top:1px solid var(--color-borde);"></div>
      </div>

      <ol style="list-style:none;padding:0;margin:0;">
        {masLeidas.map((nota, i) => (
          <li>
            <a href={`/nota/${nota.slug}`} style="display:flex;gap:0.6rem;align-items:flex-start;padding-block:0.75rem;text-decoration:none;">
              <span style="font-size:0.9rem;font-weight:700;color:var(--color-periodico);flex-shrink:0;margin-top:0.05rem;" aria-hidden="true">→</span>
              <div>
                <p style="font-family:var(--font-titular);font-size:0.875rem;font-weight:600;line-height:1.3;color:var(--color-periodico);margin:0 0 0.25rem 0;"
                   onmouseover="this.style.textDecoration='underline'"
                   onmouseout="this.style.textDecoration='none'">{nota.titulo}</p>
                <span style="font-family:var(--font-cuerpo);font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-secundario);">{nota.categoria}</span>
              </div>
            </a>
            {i < masLeidas.length - 1 && (
              <hr style="border:none;border-top:1px solid var(--color-borde);margin:0;" />
            )}
          </li>
        ))}
      </ol>
    </div>

    <!-- PUBLICIDADES SIDEBAR (dinámicas desde Sanity) -->
    {pubsSidebar.length > 0 ? (
      <div style="display:flex;flex-direction:column;gap:1rem;margin-top:0.5rem;">
        {pubsSidebar.map((pub: any) => (
          <Publicidad pub={pub} />
        ))}
      </div>
    ) : (
      <!-- Banner placeholder si no hay publicidades cargadas -->
      <div style="border:1px dashed var(--color-borde);background-color:var(--color-hueso);padding:1.5rem;text-align:center;">
        <p style="font-family:var(--font-cuerpo);font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-secundario);margin-bottom:0.6rem;">Espacio Publicitario</p>
        <p style="font-family:var(--font-titular);font-size:1.25rem;font-weight:700;color:var(--color-periodico);margin-bottom:0.4rem;line-height:1.2;">Anunciá en Reflejos</p>
        <p style="font-family:var(--font-cuerpo);font-size:0.82rem;color:var(--color-secundario);margin-bottom:1.25rem;line-height:1.4;">Llegá a toda la comunidad de San Martín</p>
        <a href="mailto:redaccion@reflejosdelaciudad.com.ar"
           style="display:block;width:100%;background-color:#111;color:#fff;font-family:var(--font-cuerpo);font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;padding:0.65rem 1rem;text-decoration:none;"
           onmouseover="this.style.backgroundColor='#333'"
           onmouseout="this.style.backgroundColor='#111'">Consultanos</a>
      </div>
    )}

  </aside>

</div>{/* fin cuerpo-grid */}

</BaseLayout>

<style>
  .hero-container { height: 280px; }
  @media (min-width: 768px) { .hero-container { height: 480px; } }

  .cuerpo-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .cuerpo-grid { grid-template-columns: 2fr 1fr; gap: 2.5rem; } }

  .notas-grid { display: grid; grid-template-columns: 1fr; gap: 1.75rem; }
  @media (min-width: 640px)  { .notas-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .notas-grid { grid-template-columns: repeat(3, 1fr); } }

  @media (max-width: 1023px) {
    aside { padding-left: 0 !important; border-left: none !important; border-top: 1px solid var(--color-borde); padding-top: 1.5rem; }
  }
</style>
