---
// src/pages/nota/[slug].astro
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { sanityClient, urlFor, portableTextToHtml } from '../../lib/sanity';
import { ARTICULO_QUERY } from '../../lib/queries';
import { SITE_URL } from '../../lib/seo';
import type { Articulo } from '../../types/article';
import Publicidad from '../../components/ui/Publicidad.astro';

export async function getStaticPaths() {
  try {
    const notas: Articulo[] = await sanityClient.fetch(
      `*[_type == "articulo"]{ slug }`
    );
    return notas.map(nota => ({ params: { slug: nota.slug.current } }));
  } catch (e) {
    console.warn('[slug] No se pudo obtener rutas estáticas:', e);
    return [];
  }
}

const { slug } = Astro.params;
let articulo: Articulo;
try {
  articulo = await sanityClient.fetch(ARTICULO_QUERY, { slug });
} catch (e) {
  console.warn(`[slug] No se pudo obtener articulo "${slug}":`, e);
  return Astro.redirect('/');
}
if (!articulo) return Astro.redirect('/');

let publicidades: any[] = [];
try {
  publicidades = await sanityClient.fetch(
    `*[_type == "publicidad" && activa == true && defined(imagen.asset->url) && defined(linkDestino)] | order(orden asc) {
      _id, nombre, linkDestino, posicion,
      "imagenUrl": imagen.asset->url
    }`
  );
} catch (e) {
  console.warn('[slug] No se pudo obtener publicidades:', e);
}

if (publicidades.length === 0) {
  try {
    publicidades = await sanityClient.fetch(
      `*[_type == "publicidad" && defined(imagen.asset->url) && defined(linkDestino)] | order(orden asc) [0..4] {
        _id, nombre, linkDestino, posicion,
        "imagenUrl": imagen.asset->url
      }`
    );
  } catch (e) {
    console.warn('[slug] No se pudo obtener publicidades de fallback:', e);
  }
}

function formatearFecha(iso: string): string {
  return new Date(iso).toLocaleDateString('es-AR', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}

// Hero — 900×506 16:9 webp, crop centrado
const imagenHero = articulo.imagen
  ? urlFor(articulo.imagen).width(900).height(506).fit('crop').format('webp').url()
  : null;

// OG image 1200×630 — ArticleLayout se encarga de pasarla al SEO via buildArticleSeo()
const imagenOg = articulo.imagen
  ? urlFor(articulo.imagen).width(1200).height(630).fit('crop').format('webp').url()
  : '/Logo.png';

const tituloCorto = articulo.titulo.length > 55
  ? articulo.titulo.slice(0, 55) + '…'
  : articulo.titulo;

const catLabel = articulo.categoria
  ? articulo.categoria.charAt(0).toUpperCase() + articulo.categoria.slice(1).toLowerCase()
  : '';

// FIX: paginaURL usa SITE_URL de seo.ts en vez de string hardcodeado a vercel.app
const paginaURL = `${SITE_URL}/nota/${slug}`;
const tituloEnc = encodeURIComponent(articulo.titulo);
const urlEnc    = encodeURIComponent(paginaURL);
const shareWA   = `https://wa.me/?text=${tituloEnc}%20${urlEnc}`;
const shareFB   = `https://www.facebook.com/sharer/sharer.php?u=${urlEnc}`;

const cuerpoHtml = portableTextToHtml(articulo.cuerpo ?? []);

// Props para ArticleLayout (buildArticleSeo + NewsArticle JSON-LD + BreadcrumbList)
const articleProps = {
  title:        articulo.titulo,
  excerpt:      articulo.bajada ?? articulo.titulo,
  slug:         articulo.slug.current,
  mainImageUrl: imagenOg !== '/Logo.png' ? imagenOg : undefined,
  publishedAt:  articulo.fechaPublicacion,
  updatedAt:    articulo._updatedAt,
  author:       articulo.autor ?? 'Redacción Reflejos',
  section:      articulo.categoria
    ? articulo.categoria.charAt(0).toUpperCase() + articulo.categoria.slice(1).toLowerCase()
    : undefined,
};
---

<ArticleLayout article={articleProps}>

<!-- ============================================================
     HERO FULL-BLEED: imagen + overlay + categoria + titulo
     ============================================================ -->
<section class="nh-section">
  <div class="nh-wrap">
    {imagenHero ? (
      <img src={imagenHero} alt={articulo.titulo} width="900" height="506" class="nh-img w-full aspect-video object-cover object-center" loading="eager" />
    ) : (
      <div class="nh-placeholder"></div>
    )}
    <div class="nh-overlay"></div>
    <div class="nh-content">
      {articulo.categoria && (
        <span class="nh-badge">{articulo.categoria}</span>
      )}
      <h1 class="nh-titulo">{articulo.titulo}</h1>
    </div>
  </div>
</section>

<!-- ============================================================
     META: breadcrumb + bajada + autor/fecha
     ============================================================ -->
<div class="nota-meta">

  <!-- Breadcrumb -->
  <nav aria-label="Ruta de navegacion" class="nota-breadcrumb">
    <ol>
      <li><a href="/">Inicio</a></li>
      <li aria-hidden="true">&rsaquo;</li>
      {articulo.categoria && (
        <>
          <li>
            <a href={`/${articulo.categoria.toLowerCase()}`}>{catLabel}</a>
          </li>
          <li aria-hidden="true">&rsaquo;</li>
        </>
      )}
      <li class="nota-breadcrumb-actual">{tituloCorto}</li>
    </ol>
  </nav>

  <!-- Bajada -->
  {articulo.bajada && (
    <p class="nota-bajada">{articulo.bajada}</p>
  )}

  <!-- Autor + Fecha -->
  <div class="nota-byline">
    <span class="nota-byline-icon" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
    </span>
    <span class="nota-autor">Por {articulo.autor}</span>
    <span class="nota-byline-sep" aria-hidden="true">&middot;</span>
    <span class="nota-byline-icon" aria-hidden="true">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </span>
    <time datetime={articulo.fechaPublicacion}>{formatearFecha(articulo.fechaPublicacion)}</time>
  </div>

  <hr class="nota-hr" />
</div>

<!-- ============================================================
     CUERPO DEL ARTICULO — Portable Text, 720px centrado
     ============================================================ -->
<div class="nota-layout grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8">
  <div class="nota-main">
    <div class="nota-cuerpo portable-text" set:html={cuerpoHtml} />

    <div class="nota-compartir">
      <hr class="nota-hr" />
      <div class="compartir-inner">
        <span class="compartir-label">Compartir</span>
        <a href={shareWA} target="_blank" rel="noopener noreferrer sponsored" class="share-btn share-wa" aria-label="Compartir en WhatsApp">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.533 5.854L0 24l6.335-1.508A11.93 11.93 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 0 1-5.034-1.388l-.361-.214-3.762.896.952-3.664-.235-.374A9.786 9.786 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
          WhatsApp
        </a>
        <a href={shareFB} target="_blank" rel="noopener noreferrer" class="share-btn share-fb" aria-label="Compartir en Facebook">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          Facebook
        </a>
        <button
          type="button"
          id="share-native-btn"
          class="share-btn share-generic"
          aria-label="Compartir nota"
          data-share-title={articulo.titulo}
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <line x1="8.6" y1="10.8" x2="15.4" y2="6.2"></line>
            <line x1="8.6" y1="13.2" x2="15.4" y2="17.8"></line>
          </svg>
          <span class="share-native-text">Compartir</span>
        </button>
      </div>
    </div>
  </div>

  <aside class="nota-sidebar">
    {publicidades.length > 0 && (
      <div class="nota-sidebar-list">
        <p class="text-xs text-gray-400 uppercase tracking-widest mb-2">Publicidad</p>
        {publicidades.map((pub: any) => (
          <Publicidad pub={pub} />
        ))}
      </div>
    )}
  </aside>
</div>

<script>
  (function () {
    var btn = document.getElementById('share-native-btn');
    if (!btn) return;

    var textEl = btn.querySelector('.share-native-text');
    var defaultLabel = textEl ? textEl.textContent : 'Compartir';
    var copiedLabel = '¡Copiado!';
    var resetTimer;

    function setTempLabel(label) {
      if (!textEl) return;
      textEl.textContent = label;
      clearTimeout(resetTimer);
      resetTimer = setTimeout(function () {
        textEl.textContent = defaultLabel;
      }, 1800);
    }

    async function copyCurrentUrl() {
      var url = window.location.href;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        await navigator.clipboard.writeText(url);
      } else {
        var textarea = document.createElement('textarea');
        textarea.value = url;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'absolute';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
      }
      setTempLabel(copiedLabel);
    }

    btn.addEventListener('click', async function () {
      var title = btn.getAttribute('data-share-title') || document.title;
      var url = window.location.href;

      if (navigator.share) {
        try {
          await navigator.share({ title: title, url: url });
          return;
        } catch (error) {
          if (error && error.name === 'AbortError') return;
        }
      }

      try {
        await copyCurrentUrl();
      } catch (error) {
        alert('No se pudo compartir ni copiar el enlace.');
      }
    });
  })();
</script>

<!-- ============================================================
     NOTAS RELACIONADAS — 3 de la misma categoria
     ============================================================ -->
{articulo.relacionadas && articulo.relacionadas.length > 0 && (
  <section class="nota-relacionadas">
    <div class="rel-header">
      <span class="rel-barra"></span>
      <h2 class="rel-titulo">También te puede interesar</h2>
      <div class="rel-linea"></div>
    </div>
    <div class="rel-grid">
      {articulo.relacionadas.map((nota) => {
        const relImg = nota.imagen
          ? urlFor(nota.imagen).width(600).height(400).fit('crop').format('webp').url()
          : `https://picsum.photos/seed/${nota.slug?.current}/600/338`;
        return (
          <article class="rel-card">
            <a href={`/nota/${nota.slug?.current}`} class="rel-img-wrap">
              <img src={relImg} alt={nota.titulo} width="600" height="400" loading="lazy" class="rel-img" />
            </a>
            <div class="rel-body">
              {nota.categoria && (
                <span class="rel-badge">{nota.categoria}</span>
              )}
              <h3 class="rel-card-titulo">
                <a href={`/nota/${nota.slug?.current}`} class="rel-card-lnk">{nota.titulo}</a>
              </h3>
              {nota.fechaPublicacion && (
                <time class="rel-fecha" datetime={nota.fechaPublicacion}>
                  {formatearFecha(nota.fechaPublicacion)}
                </time>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </section>
)}

</ArticleLayout>

<style>
  .nota-layout {
    max-width: 72rem;
    margin: 0 auto 2.5rem;
    align-items: start;
  }
  .nota-main {
    width: 100%;
    max-width: 56rem;
    justify-self: center;
  }
  .nota-sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media (min-width: 1024px) {
    .nota-sidebar {
      position: sticky;
      top: 6rem;
      align-self: start;
    }
  }

  /* ============================================================
     HERO DE NOTA
     ============================================================ */
  /* Hero full-bleed: márgenes negativos que contrarrestan el px-4/6/8 del main */
  .nh-section {
    margin-top: -1.5rem;   /* compensa py-6 del main */
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0;
    max-width: 56rem;
  }

  .nh-wrap {
    position: relative; width: 100%; aspect-ratio: 16/9;
    overflow: hidden; background: #1a1a1a;
  }

  .nh-placeholder { position: absolute; inset: 0; background: #1a1a1a; }

  .nh-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
  }
  .nh-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.45) 50%, rgba(0,0,0,0.2) 100%);
  }
  .nh-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 1.25rem 1rem;
    max-width: 1280px;
  }
  @media (min-width: 768px) { .nh-content { padding: 2rem 1.5rem; } }

  .nh-badge {
    display: inline-block; background: #111111; color: #fff;
    font-family: var(--font-cuerpo); font-size: 0.63rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    padding: 0.25rem 0.65rem; margin-bottom: 0.65rem;
  }
  .nh-titulo {
    font-family: var(--font-titular);
    font-size: clamp(1.35rem, 3.5vw, 2.6rem);
    font-weight: 700; line-height: 1.15; color: #fff;
    max-width: 52rem; margin: 0;
    text-shadow: 0 1px 5px rgba(0,0,0,0.4);
    word-break: break-word;
    overflow-wrap: break-word;
  }
  @media (max-width: 480px) {
    .nh-titulo { font-size: 1.25rem; }
    .nh-content { padding: 1rem; }
  }
</style>

<style>
  /* ============================================================
     META, BREADCRUMB, BYLINE
     ============================================================ */
  .nota-meta {
    max-width: 56rem; margin: 0 auto;
    padding-top: 1.5rem;
  }

  /* Breadcrumb */
  .nota-breadcrumb ol {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0.25rem;
    list-style: none; padding: 0; margin: 0 0 1.25rem;
    font-family: var(--font-cuerpo); font-size: 0.8rem; color: #888; /* FIX #6: era 0.75rem */
  }
  .nota-breadcrumb a { color: #888; text-decoration: none; transition: color 0.15s; }
  .nota-breadcrumb a:hover { color: #4c6a92; text-decoration: none; }
  /* FIX #6: truncar el último item (título largo) con ellipsis en mobile */
  .nota-breadcrumb-actual {
    opacity: 0.6;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  @media (min-width: 640px) {
    .nota-breadcrumb-actual { max-width: none; white-space: normal; }
  }

  /* Bajada */
  .nota-bajada {
    font-family: var(--font-titular);
    font-size: 1.2rem; font-weight: 400; font-style: italic;
    color: #4A4A4A; line-height: 1.55; margin: 0 0 1.25rem;
  }
  /* FIX #10: en mobile, el lead pierde la itálica (confunde con cuerpo) y gana
     un borde izquierdo negro para que el lector lo identifique como copete */
  @media (max-width: 640px) {
    .nota-bajada {
      font-style: normal;
      font-weight: 500;
      font-size: 1.05rem;
      border-left: 3px solid #1C1C1C;
      padding-left: 0.85rem;
    }
  }

  /* Byline */
  .nota-byline {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0.4rem;
    font-family: var(--font-cuerpo); font-size: 0.82rem; color: #666;
    margin-bottom: 1rem;
  }
  .nota-autor { font-weight: 700; color: #1a1a1a; }
  .nota-byline-sep { opacity: 0.4; }
  .nota-byline-icon { display: flex; align-items: center; opacity: 0.5; }

  /* HR separador */
  .nota-hr { border: none; border-top: 1px solid #D0D0D0; margin: 0 0 2rem; }

  /* ============================================================
     CUERPO DEL ARTICULO
     ============================================================ */
  .nota-cuerpo {
    max-width: 56rem; margin: 0 auto 2.5rem;
  }
  .nota-cuerpo p {
    font-family: var(--font-cuerpo);
    font-size: 1.125rem; line-height: 1.85;
    color: #1a1a1a; margin-bottom: 1.5rem;
  }
  /* FIX #5: reducir line-height y font-size en mobile para no requerir scroll eterno */
  @media (max-width: 640px) {
    .nota-cuerpo p {
      font-size: 1rem;       /* 16px en vez de 18px */
      line-height: 1.65;     /* era 1.85 — más compacto sin perder legibilidad */
      margin-bottom: 1.25rem;
    }
  }
  .nota-cuerpo h2, .nota-cuerpo h3 {
    font-family: var(--font-titular); font-weight: 700; color: #1a1a1a;
    margin: 2rem 0 0.75rem; padding-bottom: 0.375rem;
    border-bottom: 2px solid #D0D0D0;
  }
  .nota-cuerpo h2 { font-size: 1.5rem; }
  .nota-cuerpo h3 { font-size: 1.25rem; }
  .nota-cuerpo blockquote {
    border-left: 4px solid #4c6a92;
    margin: 2rem 0; padding: 0.75rem 1.5rem;
    background: #FAF9F7;
    font-style: italic; font-size: 1.15rem; line-height: 1.6; color: #555;
  }
  @media (max-width: 640px) {
    .nota-cuerpo blockquote {
      padding: 0.6rem 1rem;
      margin: 1.5rem 0;
      font-size: 1.05rem;
    }
  }
  .nota-cuerpo strong { font-weight: 700; color: #1a1a1a; }
  /* Drop cap SOLO en el primer párrafo real del artículo (clase .first-para).
     El selector anterior (.nota-cuerpo p:first-of-type) capturaba el epígrafe
     de foto "Foto Juventud radical" dándole una F gigante. Ahora la clase
     first-para la asigna portableTextToHtml() solo al primer <p> con >80 chars. */
  .nota-cuerpo p.first-para::first-letter {
    font-family: var(--font-titular); font-size: 3.5rem; font-weight: 900;
    line-height: 0.85; float: left; margin-right: 0.08em; margin-top: 0.1em;
    color: #1a1a1a;
  }
  @media (max-width: 640px) {
    .nota-cuerpo p.first-para::first-letter { font-size: 2.75rem; }
  }

  /* ── IMAGEN INTERCALADA ────────────────────────── */
  .nota-cuerpo .nota-img-inline {
    margin: 2rem 0;
    display: block;
  }
  .nota-cuerpo .nota-img-inline img {
    width: 100%; height: auto; display: block;
    border: 1px solid #E8E8E8;
  }
  .nota-cuerpo .nota-img-inline figcaption {
    font-family: var(--font-cuerpo);
    font-size: 0.78rem; color: #777; font-style: italic;
    margin-top: 0.4rem; padding-left: 0.25rem;
    border-left: 2px solid #D0D0D0;
  }

  /* ── VIDEO YOUTUBE RESPONSIVE ──────────────────── */
  .nota-cuerpo .yt-embed-wrap {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    margin: 2rem 0;
    background: #000;
  }
  .nota-cuerpo .yt-embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<style>
  /* ============================================================
     COMPARTIR
     ============================================================ */
  .nota-compartir { max-width: 56rem; margin: 0 auto; }

  .compartir-inner {
    display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
    padding-bottom: 2rem;
  }
  .compartir-label {
    font-family: var(--font-cuerpo); font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.18em; color: #999;
    white-space: nowrap;
  }
  .share-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    color: #fff; font-family: var(--font-cuerpo); font-size: 0.75rem;
    font-weight: 700; padding: 0.45rem 0.9rem;
    text-decoration: none; transition: opacity 0.15s;
  }
  .share-btn:hover { opacity: 0.82; text-decoration: none; }
