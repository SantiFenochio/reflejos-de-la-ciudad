---
// src/components/layout/TickerNews.astro
export interface Props {
  tickerNotas: { titulo: string; slug: { current: string } }[];
}

const { tickerNotas } = Astro.props;
---

<!-- TICKER -->
{tickerNotas.length > 0 && (
  <div class="ticker-bar" role="region" aria-label="Ultimas noticias">
    <span class="ticker-label">ÚLTIMA HORA</span>
    <!-- Skeleton: visible hasta que el DOM esté listo -->
    <div class="ticker-skeleton" aria-hidden="true">
      <span class="ticker-skel-bar" style="width:130px"></span>
      <span class="ticker-skel-dot"></span>
      <span class="ticker-skel-bar" style="width:95px;animation-delay:0.25s"></span>
      <span class="ticker-skel-dot"></span>
      <span class="ticker-skel-bar" style="width:165px;animation-delay:0.5s"></span>
      <span class="ticker-skel-dot"></span>
      <span class="ticker-skel-bar" style="width:110px;animation-delay:0.75s"></span>
    </div>
    <!-- Contenido real: oculto hasta DOMContentLoaded → fade in suave -->
    <div class="ticker-content" id="ticker-content" style="display:none;opacity:0">
      <div class="ticker-track">
        <span class="ticker-bloque">
          {tickerNotas.map((n, i) => (
            <span class="ticker-item">
              <a href={`/nota/${n.slug.current}`} class="ticker-lnk">{n.titulo}</a>
              {i < tickerNotas.length - 1 && <span class="ticker-sep" aria-hidden="true">&nbsp;&middot;&nbsp;</span>}
            </span>
          ))}
          <span class="ticker-sep" aria-hidden="true">&emsp;&middot;&emsp;</span>
        </span>
        <span class="ticker-bloque" aria-hidden="true">
          {tickerNotas.map((n, i) => (
            <span class="ticker-item">
              <a href={`/nota/${n.slug.current}`} class="ticker-lnk">{n.titulo}</a>
              {i < tickerNotas.length - 1 && <span class="ticker-sep">&nbsp;&middot;&nbsp;</span>}
            </span>
          ))}
          <span class="ticker-sep">&emsp;&middot;&emsp;</span>
        </span>
      </div>
    </div>
  </div>
)}

<style>
  /* TICKER */
  .ticker-bar { background: #111; height: 30px; display: flex; align-items: stretch; overflow: hidden; }
  .ticker-label { background: #4c6a92; color: #fff; font-family: var(--font-cuerpo); font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; padding: 0 0.85rem; display: flex; align-items: center; white-space: nowrap; flex-shrink: 0; }
  .ticker-content { flex: 1; overflow: hidden; display: flex; align-items: center; }
  .ticker-track { display: flex; white-space: nowrap; animation: ticker-scroll 28s linear infinite; }
  .ticker-bar:hover .ticker-track { animation-play-state: paused; }
  .ticker-bloque { display: inline-flex; align-items: center; }
  .ticker-item { display: inline-flex; align-items: center; }
  .ticker-lnk { font-family: var(--font-cuerpo); font-size: 0.68rem; color: rgba(245,245,240,0.78); text-decoration: none; transition: color 0.15s; }
  .ticker-lnk:hover { color: #fff; text-decoration: none; }
  .ticker-sep { color: #4c6a92; font-size: 0.75rem; }
  @keyframes ticker-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ── TICKER SKELETON ──────────────────────────────────────────── */
  .ticker-skeleton {
    flex: 1; display: flex; align-items: center;
    gap: 0.6rem; padding: 0 0.75rem; overflow: hidden;
  }
  .ticker-skel-bar {
    height: 9px; border-radius: 3px;
    background: rgba(255,255,255,0.14);
    flex-shrink: 0;
    animation: ticker-pulse 1.4s ease-in-out infinite;
  }
  .ticker-skel-dot {
    width: 3px; height: 3px; border-radius: 50%;
    background: rgba(76,106,146,0.5); flex-shrink: 0;
  }
  @keyframes ticker-pulse {
    0%, 100% { opacity: 0.3; }
    50%       { opacity: 0.75; }
  }
</style>

<script>
(function() {
  // ── Ticker: ocultar skeleton → fade in contenido real ──────────
  var skeleton = document.querySelector('.ticker-skeleton');
  var content  = document.getElementById('ticker-content');
  if (!skeleton || !content) return;
  skeleton.style.display = 'none';
  content.style.display  = 'flex';
  // Forzar reflow antes de iniciar la transición
  content.getBoundingClientRect();
  content.style.transition = 'opacity 0.35s ease';
  content.style.opacity    = '1';
})();
</script>
