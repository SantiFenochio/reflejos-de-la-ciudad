---
// src/components/layout/Header.astro
import { sanityClient } from '../../lib/sanity';
import TopBar from './TopBar.astro';
import EditionButtons from './EditionButtons.astro';
import NavBar from './NavBar.astro';
import TickerNews from './TickerNews.astro';

const secciones = [
  { label: 'Inicio',    href: '/'           },
  { label: 'Sociedad',  href: '/sociedad'   },
  { label: 'Deportes',  href: '/deportes'   },
  { label: 'Salud',     href: '/salud'      },
  { label: 'Educacion', href: '/educacion'  },
  { label: 'Seguridad', href: '/seguridad'  },
  { label: 'Cultura',   href: '/cultura'    },
  { label: 'Economia',  href: '/economia'   },
  { label: 'Vecinos',   href: '/vecinos'    },
  { label: 'Politica',  href: '/politica'   },
  { label: 'Opiniones', href: '/opiniones'  },
  { label: 'Breves',    href: '/breves'     },
];

let tickerNotas: { titulo: string; slug: { current: string } }[] = [];
try {
  tickerNotas = await sanityClient.fetch(
    `*[_type == "articulo"] | order(fechaPublicacion desc) [0...5] { titulo, slug }`
  );
} catch (e) {
  console.warn('[Header] No se pudo obtener ticker notas:', e);
}

const publicSanityProjectId: string = import.meta.env.PUBLIC_SANITY_PROJECT_ID ?? 'k3agywgt';
const publicSanityDataset: string = import.meta.env.PUBLIC_SANITY_DATASET ?? 'production';
const publicSanityApiVersion: string = '2024-01-01';
---

<TopBar />
<EditionButtons />
<NavBar
  secciones={secciones}
  publicSanityProjectId={publicSanityProjectId}
  publicSanityDataset={publicSanityDataset}
  publicSanityApiVersion={publicSanityApiVersion}
/>
<TickerNews tickerNotas={tickerNotas} />
