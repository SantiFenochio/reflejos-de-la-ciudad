---
// src/components/layout/Header.astro
import { sanityClient } from '../../lib/sanity';

const secciones = [
  { label: 'Inicio',    href: '/'           },
  { label: 'Sociedad',  href: '/sociedad'   },
  { label: 'Deportes',  href: '/deportes'   },
  { label: 'Salud',     href: '/salud'      },
  { label: 'Educacion', href: '/educacion'  },
  { label: 'Seguridad', href: '/seguridad'  },
  { label: 'Cultura',   href: '/cultura'    },
  { label: 'Economia',  href: '/economia'   },
  { label: 'Vecinos',   href: '/vecinos'    },
  { label: 'Politica',  href: '/politica'   },
  { label: 'Opiniones', href: '/opiniones'  },
  { label: 'Breves',    href: '/breves'     },
];

// Fetch de las 5 ultimas noticias para el ticker
const tickerNotas: { titulo: string; slug: { current: string } }[] = await sanityClient.fetch(
  `*[_type == "articulo"] | order(fechaPublicacion desc) [0...5] { titulo, slug }`
);
---

<!-- BARRA SUPERIOR: fecha + ubicacion -->
<div class="top-bar">
  <div class="top-inner">
    <span id="header-fecha" class="top-fecha">Cargando fecha...</span>
    <span class="top-loc">San Martin &middot; Buenos Aires</span>
  </div>
</div>

<!-- AREA LOGO -->
<div class="logo-area">
  <a href="/" aria-label="Inicio de Reflejos de la Ciudad" class="logo-link">
    <img
      src="/Logo.png"
      alt="Reflejos de la Ciudad"
      class="logo-img"
      onerror="this.style.display='none';document.getElementById('logo-text').style.display='block';"
    />
    <span id="logo-text" class="logo-text">Reflejos de la Ciudad</span>
  </a>
</div>

<!-- BARRA DE NAVEGACION ROJA (sticky) -->
<nav class="nav-bar" aria-label="Secciones del diario">

  <!-- Desktop: links horizontales -->
  <div class="nav-desktop">
    {secciones.map((s) => (
      <a href={s.href} class="nav-lnk">{s.label}</a>
    ))}
  </div>

  <!-- Mobile: nombre + boton hamburguesa -->
  <div class="nav-mobile-head">
    <span class="nav-brand">Reflejos de la Ciudad</span>
    <button id="nav-toggle" class="nav-btn" aria-label="Abrir menu" aria-expanded="false" aria-controls="nav-mobile-panel">
      <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="display:none">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile: panel desplegable -->
  <div id="nav-mobile-panel" class="nav-panel" hidden>
    {secciones.map((s) => (
      <a href={s.href} class="nav-panel-lnk">{s.label}</a>
    ))}
  </div>

</nav>

<!-- TICKER: barra negra de ultimas noticias bajo el nav -->
{tickerNotas.length > 0 && (
  <div class="ticker-bar" role="region" aria-label="Ultimas noticias">
    <span class="ticker-label">ULTIMO</span>
    <div class="ticker-content">
      <div class="ticker-track">
        <!-- Primer bloque -->
        <span class="ticker-bloque">
          {tickerNotas.map((n, i) => (
            <span class="ticker-item">
              <a href={`/nota/${n.slug.current}`} class="ticker-lnk">{n.titulo}</a>
              {i < tickerNotas.length - 1 && <span class="ticker-sep" aria-hidden="true">&nbsp;&middot;&nbsp;</span>}
            </span>
          ))}
          <span class="ticker-sep" aria-hidden="true">&emsp;&middot;&emsp;</span>
        </span>
        <!-- Segundo bloque (identico, para el loop sin corte) -->
        <span class="ticker-bloque" aria-hidden="true">
          {tickerNotas.map((n, i) => (
            <span class="ticker-item">
              <a href={`/nota/${n.slug.current}`} class="ticker-lnk">{n.titulo}</a>
              {i < tickerNotas.length - 1 && <span class="ticker-sep">&nbsp;&middot;&nbsp;</span>}
            </span>
          ))}
          <span class="ticker-sep">&emsp;&middot;&emsp;</span>
        </span>
      </div>
    </div>
  </div>
)}

<style>
  /* TOP BAR */
  .top-bar { background: #1a1a1a; border-bottom: 2px solid #C0392B; }
  .top-inner {
    max-width: 1280px; margin: 0 auto; padding: 0.35rem 1rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .top-fecha, .top-loc { font-family: var(--font-cuerpo); font-size: 0.7rem; color: #F5F5F0; letter-spacing: 0.04em; }
  .top-fecha { opacity: 0.8; }
  .top-loc   { opacity: 0.55; text-transform: uppercase; letter-spacing: 0.12em; }

  /* LOGO */
  .logo-area {
    background: #ffffff; padding: 1.25rem 1rem;
    display: flex; justify-content: center; align-items: center;
    border-bottom: 1px solid #e5e5e5;
  }
  .logo-link { display: inline-block; }
  .logo-img  { max-height: 110px; width: auto; display: block; }
  .logo-text { display: none; font-family: var(--font-titular); font-weight: 900; font-size: 2.25rem; color: #1a1a1a; letter-spacing: -0.02em; }

  /* NAV ROJO */
  .nav-bar { background: #C0392B; position: sticky; top: 0; z-index: 50; box-shadow: 0 2px 8px rgba(0,0,0,0.28); }

  .nav-desktop { display: none; max-width: 1280px; margin: 0 auto; padding: 0 0.5rem; justify-content: center; flex-wrap: wrap; align-items: stretch; }
  @media (min-width: 768px) { .nav-desktop { display: flex; } }

  .nav-lnk {
    font-family: var(--font-cuerpo); font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em; color: #ffffff;
    padding: 0.65rem 0.6rem; display: inline-block; white-space: nowrap;
    text-decoration: none; transition: background-color 0.15s;
  }
  .nav-lnk:hover { background-color: rgba(0,0,0,0.2); text-decoration: none; }

  .nav-mobile-head { display: flex; justify-content: space-between; align-items: center; padding: 0 1rem; min-height: 44px; }
  @media (min-width: 768px) { .nav-mobile-head { display: none; } }
  .nav-brand { font-family: var(--font-titular); font-size: 1rem; font-weight: 700; color: #fff; }
  .nav-btn { background: none; border: none; cursor: pointer; color: #fff; padding: 0.25rem; display: flex; align-items: center; }

  .nav-panel { background: #a93226; border-top: 1px solid rgba(255,255,255,0.15); }
  .nav-panel-lnk {
    display: block; padding: 0.75rem 1.25rem;
    font-family: var(--font-cuerpo); font-size: 0.8rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em; color: #fff;
    border-bottom: 1px solid rgba(255,255,255,0.1); text-decoration: none; transition: background-color 0.15s;
  }
  .nav-panel-lnk:hover { background-color: rgba(0,0,0,0.2); text-decoration: none; }

  /* TICKER */
  .ticker-bar {
    background: #111111; height: 30px;
    display: flex; align-items: stretch; overflow: hidden;
  }
  .ticker-label {
    background: #C0392B; color: #fff;
    font-family: var(--font-cuerpo); font-size: 0.58rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    padding: 0 0.85rem; display: flex; align-items: center;
    white-space: nowrap; flex-shrink: 0;
  }
  .ticker-content { flex: 1; overflow: hidden; display: flex; align-items: center; }
  .ticker-track {
    display: flex; white-space: nowrap;
    animation: ticker-scroll 28s linear infinite;
  }
  .ticker-bar:hover .ticker-track { animation-play-state: paused; }
  .ticker-bloque { display: inline-flex; align-items: center; }
  .ticker-item { display: inline-flex; align-items: center; }
  .ticker-lnk {
    font-family: var(--font-cuerpo); font-size: 0.68rem; color: rgba(245,245,240,0.78);
    text-decoration: none; transition: color 0.15s;
  }
  .ticker-lnk:hover { color: #fff; text-decoration: none; }
  .ticker-sep { color: #C0392B; font-size: 0.75rem; }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>

<script>
  (function() {
    // Fecha dinamica
    const el = document.getElementById('header-fecha');
    if (el) {
      const f = new Date().toLocaleDateString('es-AR', {
        weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
      });
      el.textContent = f.charAt(0).toUpperCase() + f.slice(1);
    }
    // Toggle mobile menu
    const btn   = document.getElementById('nav-toggle');
    const panel = document.getElementById('nav-mobile-panel');
    const iM    = document.getElementById('icon-menu');
    const iC    = document.getElementById('icon-close');
    if (btn && panel) {
      btn.addEventListener('click', function() {
        const open = !panel.hidden;
        panel.hidden = open;
        btn.setAttribute('aria-expanded', String(!open));
        if (iM) iM.style.display = open ? 'block' : 'none';
        if (iC) iC.style.display = open ? 'none'  : 'block';
      });
      panel.querySelectorAll('a').forEach(function(a) {
        a.addEventListener('click', function() {
          panel.hidden = true;
          btn.setAttribute('aria-expanded', 'false');
          if (iM) iM.style.display = 'block';
          if (iC) iC.style.display = 'none';
        });
      });
    }
  })();
</script>
