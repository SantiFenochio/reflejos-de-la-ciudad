---
// src/components/layout/Header.astro
import { sanityClient } from '../../lib/sanity';
import { Image } from 'astro:assets';
import imgEdicionesAnteriores from '../../assets/Anteriores17.png';
import imgUltimaEdicion       from '../../assets/ultima17.png';
import imgIconoDerecha        from '../../assets/96Actual.png';

const secciones = [
  { label: 'Inicio',    href: '/'           },
  { label: 'Sociedad',  href: '/sociedad'   },
  { label: 'Deportes',  href: '/deportes'   },
  { label: 'Salud',     href: '/salud'      },
  { label: 'Educacion', href: '/educacion'  },
  { label: 'Seguridad', href: '/seguridad'  },
  { label: 'Cultura',   href: '/cultura'    },
  { label: 'Economia',  href: '/economia'   },
  { label: 'Vecinos',   href: '/vecinos'    },
  { label: 'Politica',  href: '/politica'   },
  { label: 'Opiniones', href: '/opiniones'  },
  { label: 'Breves',    href: '/breves'     },
];

let tickerNotas: { titulo: string; slug: { current: string } }[] = [];
try {
  tickerNotas = await sanityClient.fetch(
    `*[_type == "articulo"] | order(fechaPublicacion desc) [0...5] { titulo, slug }`
  );
} catch (e) {
  console.warn('[Header] No se pudo obtener ticker notas:', e);
}

// Traemos el PDF de la edición impresa más reciente (ordenada por fecha DESC)
let ultimaEdicion: { pdfUrl: string | null } | null = null;
try {
  ultimaEdicion = await sanityClient.fetch<{ pdfUrl: string | null }>(
    `*[_type == "edicionImpresa"] | order(fecha desc)[0] { "pdfUrl": archivoPdf.asset->url }`
  );
} catch (e) {
  console.warn('[Header] No se pudo obtener ultima edicion:', e);
}
const linkEdicionActual: string = ultimaEdicion?.pdfUrl ?? '/edicion-actual.pdf';
const publicSanityProjectId: string = import.meta.env.PUBLIC_SANITY_PROJECT_ID ?? 'k3agywgt';
const publicSanityDataset: string = import.meta.env.PUBLIC_SANITY_DATASET ?? 'production';
const publicSanityApiVersion: string = '2024-01-01';
---

<!-- BARRA SUPERIOR -->
<div class="top-bar">
  <div class="top-inner">
    <div class="top-left">
      <span id="header-fecha" class="top-fecha">Cargando fecha...</span>
      <span id="clima-widget" class="top-clima" aria-label="Clima actual en San Martin"></span>
    </div>
    <span class="top-loc">San Martin &middot; Buenos Aires</span>
  </div>
</div>

<!-- LOGO -->
<div class="logo-area-bg">
<div class="logo-area">

  <!-- ZONA IZQUIERDA: RRSS + Imagen 96 años -->
  <div class="logo-zona-izq">

    <!-- 1: RRSS -->
    <div class="logo-col-rrss">
      <a
        href="https://www.facebook.com/reflejosdelaciudad"
        target="_blank"
        rel="noopener noreferrer"
        class="rrss-lnk"
        aria-label="Seguinos en Facebook"
      >
        <div class="rrss-box rrss-box-fb">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </div>
      </a>
      <a
        href="https://www.instagram.com/reflejosdelaciudad/"
        target="_blank"
        rel="noopener noreferrer"
        class="rrss-lnk"
        aria-label="Seguinos en Instagram"
      >
        <div class="rrss-box rrss-box-ig">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </div>
      </a>
    </div>

    <!-- 2: Ícono 96 años -->
    <div class="logo-col-derecha">
      <Image
        src={imgIconoDerecha}
        alt="96 Años de Periodismo Local"
        class="logo-btn-img logo-img-96"
      />
    </div>

  </div>

  <!-- ZONA CENTRO: Logo principal -->
  <div class="logo-zona-centro">
    <div class="logo-center">
      <a href="/" aria-label="Inicio de Reflejos de la Ciudad" class="logo-link">
        <img
          src="/Logo.png"
          alt="Reflejos de la Ciudad"
          class="logo-img"
          onerror="this.style.display='none';document.getElementById('logo-text').style.display='block';"
        />
        <span id="logo-text" class="logo-text">Reflejos de la Ciudad</span>
      </a>
    </div>
  </div>

  <!-- ZONA DERECHA: Ediciones Anteriores + Edición Actual -->
  <div class="logo-zona-der">

    <!-- 4: Ediciones Anteriores — imagen original con hover de fondo -->
    <div class="logo-btn-lateral">
      <a href="/edicionesanteriores" aria-label="Ver ediciones anteriores del diario" class="logo-btn-edicion">
        <Image src={imgEdicionesAnteriores} alt="Ver Ediciones Anteriores" class="logo-btn-img" />
      </a>
    </div>

    <!-- Separador vertical entre botones -->
    <div class="logo-btn-sep" aria-hidden="true"></div>

    <!-- 5: Edición Actual PDF — imagen original con hover de fondo -->
    <div class="logo-btn-lateral">
      <a href={linkEdicionActual} target="_blank" rel="noopener noreferrer" aria-label="Ver edición actual en PDF" class="logo-btn-edicion">
        <Image src={imgUltimaEdicion} alt="Ver Edición Actual" class="logo-btn-img" />
      </a>
    </div>

  </div>

</div>
</div>

<!-- BARRA EDICIONES MOBILE — solo visible < 768px -->
<div class="ediciones-mobile-bar">
  <a href="/edicionesanteriores" class="edicion-mobile-btn" aria-label="Ver ediciones anteriores del diario">
    <Image src={imgEdicionesAnteriores} alt="Ver Ediciones Anteriores" class="edicion-mobile-img" />
  </a>
  <a href={linkEdicionActual} target="_blank" rel="noopener noreferrer" class="edicion-mobile-btn" aria-label="Ver última edición semanal en PDF">
    <Image src={imgUltimaEdicion} alt="Ver Última Edición Semanal" class="edicion-mobile-img" />
  </a>
</div>

<!-- NAV ROJO -->
<nav class="nav-bar" aria-label="Secciones del diario">
  <!-- Desktop -->
  <div class="nav-desktop">
    {secciones.map((s) => (
      <a href={s.href} class="nav-lnk">{s.label}</a>
    ))}
    <!-- Lupa buscador desktop -->
    <button id="search-toggle-desk" class="nav-search-btn" aria-label="Abrir buscador" aria-expanded="false">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>
  </div>
  <!-- Mobile head -->
  <div class="nav-mobile-head">
    <!-- FIX #11: se eliminó el <span class="nav-brand"> "Reflejos de la Ciudad"
         porque el logo ya está arriba — era redundante y ocupaba espacio valioso -->
    <div style="display:flex;align-items:center;gap:0.5rem;margin-left:auto;">
      <!-- Lupa buscador mobile -->
      <button id="search-toggle-mob" class="nav-search-btn" aria-label="Abrir buscador" aria-expanded="false">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <button id="nav-toggle" class="nav-btn" aria-label="Abrir menu" aria-expanded="false" aria-controls="nav-mobile-panel">
        <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="display:none">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
  <!-- Mobile panel -->
  <div id="nav-mobile-panel" class="nav-panel" hidden>
    {secciones.map((s) => (
      <a href={s.href} class="nav-panel-lnk">{s.label}</a>
    ))}
  </div>
</nav>

<!-- BUSCADOR — panel deslizable debajo del nav -->
<div id="buscador-panel" class="buscador-panel" hidden>
  <div class="buscador-wrap">
    <div class="buscador-input-row">
      <svg class="buscador-ico" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input id="buscador-input" type="search" placeholder="Buscar noticias..." class="buscador-input" autocomplete="off" spellcheck="false" />
      <button id="buscador-close" class="buscador-close" aria-label="Cerrar buscador">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div id="buscador-resultados" class="buscador-resultados" hidden></div>
  </div>
</div>

<!-- TICKER -->
{tickerNotas.length > 0 && (
  <div class="ticker-bar" role="region" aria-label="Ultimas noticias">
    <span class="ticker-label">ÚLTIMA HORA</span>
    <div class="ticker-content">
      <div class="ticker-track">
        <span class="ticker-bloque">
          {tickerNotas.map((n, i) => (
            <span class="ticker-item">
              <a href={`/nota/${n.slug.current}`} class="ticker-lnk">{n.titulo}</a>
              {i < tickerNotas.length - 1 && <span class="ticker-sep" aria-hidden="true">&nbsp;&middot;&nbsp;</span>}
            </span>
          ))}
          <span class="ticker-sep" aria-hidden="true">&emsp;&middot;&emsp;</span>
        </span>
        <span class="ticker-bloque" aria-hidden="true">
          {tickerNotas.map((n, i) => (
            <span class="ticker-item">
              <a href={`/nota/${n.slug.current}`} class="ticker-lnk">{n.titulo}</a>
              {i < tickerNotas.length - 1 && <span class="ticker-sep">&nbsp;&middot;&nbsp;</span>}
            </span>
          ))}
          <span class="ticker-sep">&emsp;&middot;&emsp;</span>
        </span>
      </div>
    </div>
  </div>
)}

<style>
  /* TOP BAR */
  .top-bar { background: #1a1a1a; border-bottom: 2px solid #4c6a92; }
  .top-inner { max-width: 1280px; margin: 0 auto; padding: 0.35rem 1rem; display: flex; justify-content: space-between; align-items: center; }
  .top-left { display: flex; align-items: center; gap: 0.75rem; }
  .top-fecha, .top-loc { font-family: var(--font-cuerpo); font-size: 0.7rem; color: #F5F5F0; letter-spacing: 0.04em; }
  .top-fecha { opacity: 0.8; }
  .top-loc   { opacity: 0.55; text-transform: uppercase; letter-spacing: 0.12em; }
  .top-clima {
    font-family: var(--font-cuerpo); font-size: 0.7rem; color: #F5F5F0;
    opacity: 0.75; letter-spacing: 0.03em;
    border-left: 1px solid rgba(255,255,255,0.2);
    padding-left: 0.75rem;
  }
  /* FIX #9: topbar compacta en mobile, clima oculto para ahorrar espacio */
  @media (max-width: 640px) {
    .top-inner { padding: 0.2rem 0.75rem; }
    .top-fecha  { font-size: 0.62rem; }
    .top-loc    { font-size: 0.62rem; }
    .top-clima  { display: none; }
  }

  /* ── LOGO AREA — wrapper full-width para que el blanco cubra todo el ancho ── */
  .logo-area-bg {
    background: #fff;
    border-bottom: 2px solid #1a1a1a; /* filete oscuro tipo masthead periodístico */
  }

  /* ── LOGO AREA — 3 zonas de 33% con space-between ── */
  .logo-area {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    min-height: 220px;
    box-sizing: border-box;
  }

  /* Zona izquierda: RRSS + Ediciones Anteriores */
  .logo-zona-izq {
    display: flex;
    align-items: center;
    gap: 3rem;
    width: 30%;
    justify-content: flex-start;
  }

  /* Zona centro: Logo */
  .logo-zona-centro {
    display: flex;
    justify-content: center;
    width: 40%;
  }

  /* Zona derecha: Edición Actual + 96 años */
  .logo-zona-der {
    display: flex;
    align-items: center;
    gap: 3rem;
    width: 30%;
    justify-content: flex-end;
  }

  /* 1 — RRSS: cajas de color 44×44px con border-radius 8px */
  .logo-col-rrss {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .rrss-lnk {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    line-height: 0;
    transition: opacity 0.2s ease;
  }
  .rrss-lnk:hover { opacity: 0.85; text-decoration: none; }
  /* Caja genérica: 44×44, cuadrado redondeado */
  .rrss-box {
    width: 44px; height: 44px;   /* era 38×38 */
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .rrss-box-fb { background: #1877F2; }
  .rrss-box-ig {
    background: linear-gradient(135deg, #E1306C 0%, #833AB4 50%, #405DE6 100%);
  }

  /* 2 & 4 — Botones laterales de edición: envuelven la imagen con hover de fondo */
  .logo-btn-lateral { display: flex; align-items: center; flex-shrink: 0; }

  /* Enlace de edición: padding + hover suave */
  .logo-btn-edicion {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    text-decoration: none;
    border-radius: 6px;
    transition: background-color 0.2s ease;
  }
  .logo-btn-edicion:hover {
    background-color: #F0F0F0;
    text-decoration: none;
  }

  /* Imagen de edición: 90px de alto */
  .logo-btn-img {
    display: block;
    height: 90px;   /* era 80px */
    width: auto;
    max-width: 200px;
    object-fit: contain;
  }

  /* Separador vertical entre los dos botones — ajustado a la nueva altura */
  .logo-btn-sep {
    width: 1px;
    height: 90px;   /* proporcional a las imágenes */
    background: #D0D0D0;
    flex-shrink: 0;
    margin: 0 0.25rem;
  }

  /* 3 — Logo central */
  .logo-center { display: flex; align-items: center; flex-shrink: 0; }
  .logo-link   { display: inline-block; }
  .logo-img    { display: block; width: 560px; height: auto; max-width: 100%; }
  .logo-text   { display: none; font-family: var(--font-titular); font-weight: 900; font-size: 2.25rem; color: #1a1a1a; letter-spacing: -0.02em; }

  /* 5 — Ícono 96 años: crecer junto al banner */
  .logo-col-derecha { display: flex; align-items: center; flex-shrink: 0; }
  .logo-img-96 { height: 180px !important; width: auto; object-fit: contain; }

  /* ── MOBILE < 768px: solo el logo centrado ── */
  @media (max-width: 767px) {
    .logo-area {
      justify-content: center;
      padding: 0.75rem 1rem;
      min-height: auto;
    }
    .logo-zona-izq    { display: none; }
    .logo-zona-centro { width: 100%; justify-content: center; }
    .logo-zona-der    { display: none; }
    .logo-img         { width: 190px; height: auto; max-width: 72vw; }
  }

  /* NAV */
  .nav-bar { background: #4c6a92; position: sticky; top: 0; z-index: 50; box-shadow: 0 2px 8px rgba(0,0,0,0.28); border-top: 3px solid #1a1a1a; }
  .nav-desktop { display: none; max-width: 1280px; margin: 0 auto; padding: 0 0.5rem; justify-content: center; flex-wrap: wrap; align-items: stretch; }
  @media (min-width: 768px) { .nav-desktop { display: flex; } }
  .nav-lnk { font-family: var(--font-cuerpo); font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; padding: 0.65rem 0.6rem; display: inline-block; white-space: nowrap; text-decoration: none; transition: background-color 0.15s; }
  .nav-lnk:hover { background-color: rgba(0,0,0,0.2); text-decoration: none; }
  /* Lupa */
  .nav-search-btn { background: none; border: none; cursor: pointer; color: #fff; padding: 0.65rem 0.6rem; display: flex; align-items: center; transition: background-color 0.15s; margin-left: auto; }
  .nav-search-btn:hover { background-color: rgba(0,0,0,0.2); }
  .nav-mobile-head { display: flex; justify-content: space-between; align-items: center; padding: 0 1rem; min-height: 44px; }
  @media (min-width: 768px) { .nav-mobile-head { display: none; } }
  .nav-brand { font-family: var(--font-titular); font-size: 1rem; font-weight: 700; color: #fff; }
  .nav-btn {
    background: none; border: none; cursor: pointer; color: #fff;
    /* Área táctil mínima recomendada: 44x44px */
    min-width: 44px; min-height: 44px;
    padding: 0.6rem;
    display: flex; align-items: center; justify-content: center;
  }
  .nav-panel { background: #3b5475; border-top: 1px solid rgba(255,255,255,0.15); }
  .nav-panel-lnk { display: block; padding: 0.75rem 1.25rem; font-family: var(--font-cuerpo); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.1); text-decoration: none; transition: background-color 0.15s; }
  .nav-panel-lnk:hover { background-color: rgba(0,0,0,0.2); text-decoration: none; }

  /* BUSCADOR PANEL */
  .buscador-panel {
    background: #fff;
    border-bottom: 2px solid #D0D0D0;
    position: sticky; top: 44px; z-index: 49;
    animation: slideDown 0.2s ease;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  @keyframes slideDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
  .buscador-wrap { max-width: 720px; margin: 0 auto; padding: 0.75rem 1rem; }
  .buscador-input-row { display: flex; align-items: center; gap: 0.5rem; border: 1.5px solid #D0D0D0; background: #F9F9F7; padding: 0.5rem 0.75rem; }
  .buscador-ico { flex-shrink: 0; }
  .buscador-input {
    flex: 1; border: none; background: transparent; outline: none;
    font-family: var(--font-cuerpo); font-size: 1rem; color: #1a1a1a;
    min-width: 0;
  }
  .buscador-input::placeholder { color: #aaa; }
  .buscador-close { background: none; border: none; cursor: pointer; color: #888; padding: 0.2rem; display: flex; align-items: center; transition: color 0.15s; }
  .buscador-close:hover { color: #4c6a92; }

  /* RESULTADOS */
  .buscador-resultados { margin-top: 0.5rem; border: 1px solid #E8E8E8; background: #fff; max-height: 320px; overflow-y: auto; }
  .buscador-resultado {
    display: flex; gap: 0.75rem; align-items: flex-start;
    padding: 0.65rem 0.75rem; border-bottom: 1px solid #F0F0EC;
    text-decoration: none; color: inherit;
    transition: background-color 0.15s;
  }
  .buscador-resultado:hover { background: #F5F5F0; text-decoration: none; }
  .buscador-resultado:last-child { border-bottom: none; }
  .buscador-res-img { width: 56px; height: 38px; object-fit: cover; flex-shrink: 0; background: #e0e0e0; display: block; }
  .buscador-res-body { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .buscador-res-cat { font-family: var(--font-cuerpo); font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #4c6a92; }
  .buscador-res-titulo { font-family: var(--font-titular); font-size: 0.9rem; font-weight: 600; color: #1a1a1a; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .buscador-empty { font-family: var(--font-cuerpo); font-size: 0.85rem; color: #888; padding: 1rem; text-align: center; }
  .buscador-loading { font-family: var(--font-cuerpo); font-size: 0.85rem; color: #aaa; padding: 1rem; text-align: center; }

  /* BARRA EDICIONES MOBILE */
  .ediciones-mobile-bar {
    display: none; /* oculta en desktop */
  }
  @media (max-width: 767px) {
    .ediciones-mobile-bar {
      display: flex;
      background: #fff;
      border-top: 1px solid #D0D0D0;
      border-bottom: 2px solid #1C1C1C;
    }
    .edicion-mobile-btn {
      flex: 1;
      min-height: 74px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1C1C1C;
      text-decoration: none;
      padding: 0.45rem 0.4rem;
      border-right: 1px solid #D0D0D0;
      transition: background-color 0.15s;
    }
    .edicion-mobile-btn:last-child { border-right: none; }
    .edicion-mobile-btn:active     { background: #e8e8e8; }
    .edicion-mobile-img {
      display: block;
      height: 60px;
      width: auto;
      max-width: 100%;
      object-fit: contain;
    }
  }

  /* TICKER */
  .ticker-bar { background: #111; height: 30px; display: flex; align-items: stretch; overflow: hidden; }
  .ticker-label { background: #4c6a92; color: #fff; font-family: var(--font-cuerpo); font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; padding: 0 0.85rem; display: flex; align-items: center; white-space: nowrap; flex-shrink: 0; }
  .ticker-content { flex: 1; overflow: hidden; display: flex; align-items: center; }
  .ticker-track { display: flex; white-space: nowrap; animation: ticker-scroll 28s linear infinite; }
  .ticker-bar:hover .ticker-track { animation-play-state: paused; }
  .ticker-bloque { display: inline-flex; align-items: center; }
  .ticker-item { display: inline-flex; align-items: center; }
  .ticker-lnk { font-family: var(--font-cuerpo); font-size: 0.68rem; color: rgba(245,245,240,0.78); text-decoration: none; transition: color 0.15s; }
  .ticker-lnk:hover { color: #fff; text-decoration: none; }
  .ticker-sep { color: #4c6a92; font-size: 0.75rem; }
  @keyframes ticker-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
</style>

<script define:vars={{ publicSanityProjectId, publicSanityDataset, publicSanityApiVersion }}>
(function() {
  // ── Fecha dinamica ──────────────────────────────────────────────
  const el = document.getElementById('header-fecha');
  if (el) {
    const f = new Date().toLocaleDateString('es-AR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
    el.textContent = f.charAt(0).toUpperCase() + f.slice(1);
  }

  // ── Widget clima (Open-Meteo, sin API key) ───────────────────────
  (async function() {
    var widget = document.getElementById('clima-widget');
    if (!widget) return;
    try {
      var res  = await fetch('https://api.open-meteo.com/v1/forecast?latitude=-34.5772&longitude=-58.5398&current=temperature_2m,weather_code&timezone=America%2FSao_Paulo');
      var data = await res.json();
      var temp = Math.round(data.current.temperature_2m);
      var code = data.current.weather_code;
      var emoji = '🌤️';
      if (code === 0)                              emoji = '☀️';
      else if (code <= 3)                          emoji = '⛅';
      else if (code <= 48)                         emoji = '🌫️';
      else if (code <= 67)                         emoji = '🌧️';
      else if (code <= 77)                         emoji = '❄️';
      else if (code <= 82)                         emoji = '🌧️';
      else if (code <= 99)                         emoji = '⛈️';
      widget.textContent = emoji + ' ' + temp + '°C';
    } catch(e) {
      // Falla silenciosamente — el widget simplemente queda vacío
      var w = document.getElementById('clima-widget');
      if (w) w.style.display = 'none';
    }
  })();

  // ── Toggle mobile menu ──────────────────────────────────────────
  const btn   = document.getElementById('nav-toggle');
  const panel = document.getElementById('nav-mobile-panel');
  const iM    = document.getElementById('icon-menu');
  const iC    = document.getElementById('icon-close');
  if (btn && panel) {
    btn.addEventListener('click', function() {
      const open = !panel.hidden;
      panel.hidden = open;
      btn.setAttribute('aria-expanded', String(!open));
      if (iM) iM.style.display = open ? 'block' : 'none';
      if (iC) iC.style.display = open ? 'none'  : 'block';
      // Scroll-lock: bloquear scroll del fondo cuando el menú está abierto
      document.body.style.overflow = open ? '' : 'hidden';
    });
    panel.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        panel.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
        if (iM) iM.style.display = 'block';
        if (iC) iC.style.display = 'none';
        // Liberar scroll al navegar
        document.body.style.overflow = '';
      });
    });
  }

  // ── Buscador ────────────────────────────────────────────────────
  var SANITY_PROJECT = publicSanityProjectId;
  var SANITY_DATASET = publicSanityDataset;
  var SANITY_VER     = publicSanityApiVersion;

  var buscadorPanel = document.getElementById('buscador-panel');
  var buscadorInput = document.getElementById('buscador-input');
  var buscadorClose = document.getElementById('buscador-close');
  var buscadorRes   = document.getElementById('buscador-resultados');
  var toggleDesk    = document.getElementById('search-toggle-desk');
  var toggleMob     = document.getElementById('search-toggle-mob');
  var debounceTimer = null;

  function abrirBuscador() {
    if (!buscadorPanel) return;
    buscadorPanel.hidden = false;
    if (buscadorInput) buscadorInput.focus();
    if (toggleDesk) toggleDesk.setAttribute('aria-expanded', 'true');
    if (toggleMob)  toggleMob.setAttribute('aria-expanded', 'true');
  }

  function cerrarBuscador() {
    if (!buscadorPanel) return;
    buscadorPanel.hidden = true;
    if (buscadorInput) buscadorInput.value = '';
    if (buscadorRes)   { buscadorRes.hidden = true; buscadorRes.innerHTML = ''; }
    if (toggleDesk) toggleDesk.setAttribute('aria-expanded', 'false');
    if (toggleMob)  toggleMob.setAttribute('aria-expanded', 'false');
  }

  if (toggleDesk) toggleDesk.addEventListener('click', function() {
    buscadorPanel.hidden ? abrirBuscador() : cerrarBuscador();
  });
  if (toggleMob) toggleMob.addEventListener('click', function() {
    buscadorPanel.hidden ? abrirBuscador() : cerrarBuscador();
  });
  if (buscadorClose) buscadorClose.addEventListener('click', cerrarBuscador);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') cerrarBuscador();
  });
  document.addEventListener('click', function(e) {
    if (buscadorPanel && !buscadorPanel.hidden) {
      var t = e.target;
      if (!buscadorPanel.contains(t) && t !== toggleDesk && t !== toggleMob &&
          !toggleDesk?.contains(t) && !toggleMob?.contains(t)) {
        cerrarBuscador();
      }
    }
  });

  function mostrarResultados(notas) {
    if (!buscadorRes) return;
    if (!notas || notas.length === 0) {
      buscadorRes.innerHTML = '<p class="buscador-empty">No se encontraron resultados.</p>';
      buscadorRes.hidden = false;
      return;
    }
    buscadorRes.innerHTML = notas.map(function(n) {
      var img = n.imgUrl
        ? '<img class="buscador-res-img" src="' + n.imgUrl + '?w=112&h=76&fit=crop&auto=format" alt="" loading="lazy">'
        : '<div class="buscador-res-img" style="background:#e0e0e0;"></div>';
      return '<a href="/nota/' + n.slug + '" class="buscador-resultado">'
        + img
        + '<div class="buscador-res-body">'
        + '<span class="buscador-res-titulo">' + n.titulo + '</span>'
        + '</div></a>';
    }).join('');
    buscadorRes.hidden = false;
    buscadorRes.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', cerrarBuscador);
    });
  }

  async function buscar(q) {
    if (!buscadorRes) return;
    buscadorRes.innerHTML = '<p class="buscador-loading">Buscando...</p>';
    buscadorRes.hidden = false;
    try {
      // GROQ: match requiere wildcards en el valor del parámetro, no en la query.
      // Se usa api.sanity.io (no apicdn) para evitar problemas de CORS y caché.
      var query = '*[_type == "articulo" && titulo match $q] | order(fechaPublicacion desc)[0...8] { titulo, "slug": slug.current, "imgUrl": imagenPrincipal.asset->url }';
      var url = 'https://' + SANITY_PROJECT + '.api.sanity.io/v' + SANITY_VER + '/data/query/' + SANITY_DATASET
        + '?query=' + encodeURIComponent(query)
        + '&$q=' + encodeURIComponent(JSON.stringify('*' + q + '*'));
      var res  = await fetch(url);
      if (!res.ok) throw new Error('HTTP ' + res.status);
      var data = await res.json();
      mostrarResultados(data.result || []);
    } catch(err) {
      console.error('[Buscador]', err);
      buscadorRes.innerHTML = '<p class="buscador-empty">Error al buscar. Intenta de nuevo.</p>';
    }
  }

  if (buscadorInput) {
    buscadorInput.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      var val = this.value.trim();
      if (!val) {
        if (buscadorRes) { buscadorRes.hidden = true; buscadorRes.innerHTML = ''; }
        return;
      }
      debounceTimer = setTimeout(function() { buscar(val); }, 300);
    });
  }
})();
</script>
