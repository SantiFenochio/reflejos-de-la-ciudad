---
// src/components/layout/Footer.astro

const navLinks = [
  { label: 'Inicio',    href: '/'          },
  { label: 'Sociedad',  href: '/sociedad'  },
  { label: 'Deportes',  href: '/deportes'  },
  { label: 'Cultura',   href: '/cultura'   },
  { label: 'Política',  href: '/politica'  },
  { label: 'Contacto',  href: '/contacto'  },
];

const anio = new Date().getFullYear();
---

<footer style="background-color: #1C1C1C; color: #F5F5F0;">

  <!-- ════════════════════════════════════════════════════════
       GRID PRINCIPAL: 3 columnas desktop, apiladas en mobile
  ═════════════════════════════════════════════════════════════ -->
  <div class="footer-grid max-w-screen-xl mx-auto px-4 py-12">

    <!-- ── COLUMNA IZQUIERDA: identidad del diario ───────── -->
    <div>
      <p style="
        font-family: var(--font-titular);
        font-size: 1.5rem;
        font-weight: 700;
        color: #F5F5F0;
        margin-bottom: 0.5rem;
        line-height: 1.2;
      ">
        Reflejos de la Ciudad
      </p>

      <p style="
        font-family: var(--font-cuerpo);
        font-size: 0.8rem;
        color: #F5F5F0;
        opacity: 0.5;
        margin-bottom: 0.75rem;
      ">
        Semanario del barrio desde 1990
      </p>

      <p style="
        font-family: var(--font-cuerpo);
        font-size: 0.8rem;
        color: #F5F5F0;
        opacity: 0.65;
        letter-spacing: 0.04em;
      ">
        Villa Ballester &middot; Gral. San Martín &middot; Buenos Aires
      </p>
    </div>


    <!-- ── COLUMNA CENTRAL: navegación ──────────────────── -->
    <div>
      <p style="
        font-family: var(--font-cuerpo);
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #F5F5F0;
        opacity: 0.45;
        margin-bottom: 1rem;
      ">
        Navegación
      </p>

      <nav aria-label="Links del footer">
        {navLinks.map((link) => (
          <a
            href={link.href}
            style="
              display: block;
              font-family: var(--font-cuerpo);
              font-size: 0.85rem;
              color: #F5F5F0;
              opacity: 0.7;
              margin-bottom: 0.5rem;
              transition: opacity 0.15s ease;
            "
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.7'"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>


    <!-- ── COLUMNA DERECHA: contacto + redes ─────────────── -->
    <div>
      <p style="
        font-family: var(--font-cuerpo);
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #F5F5F0;
        opacity: 0.45;
        margin-bottom: 1rem;
      ">
        Contacto
      </p>

      <a
        href="mailto:redaccion@reflejosdelaciudad.com.ar"
        style="
          font-family: var(--font-cuerpo);
          font-size: 0.82rem;
          color: #F5F5F0;
          opacity: 0.75;
          display: block;
          margin-bottom: 1.25rem;
          transition: opacity 0.15s ease;
          word-break: break-all;
        "
        onmouseover="this.style.opacity='1'"
        onmouseout="this.style.opacity='0.75'"
      >
        redaccion@reflejosdelaciudad.com.ar
      </a>

      <!-- Íconos redes sociales en SVG inline, sin librerías -->
      <div style="display: flex; gap: 1rem; align-items: center;">


        <!-- Facebook -->
        <a
          href="#"
          aria-label="Facebook de Reflejos de la Ciudad"
          style="color: #F5F5F0; opacity: 0.65; transition: opacity 0.15s ease; display: inline-flex;"
          onmouseover="this.style.opacity='1'"
          onmouseout="this.style.opacity='0.65'"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </a>

        <!-- Instagram -->
        <a
          href="#"
          aria-label="Instagram de Reflejos de la Ciudad"
          style="color: #F5F5F0; opacity: 0.65; transition: opacity 0.15s ease; display: inline-flex;"
          onmouseover="this.style.opacity='1'"
          onmouseout="this.style.opacity='0.65'"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>

      </div>
    </div>

  </div>


  <!-- ════════════════════════════════════════════════════════
       BARRA INFERIOR: separador + copyright
  ═════════════════════════════════════════════════════════════ -->
  <div style="border-top: 1px solid #2E2E2E;">
    <div
      class="max-w-screen-xl mx-auto px-4 py-4"
      style="text-align: center;"
    >
      <p style="
        font-family: var(--font-cuerpo);
        font-size: 0.75rem;
        color: #F5F5F0;
        opacity: 0.4;
        letter-spacing: 0.03em;
      ">
        &copy; {anio} Reflejos de la Ciudad &middot; Todos los derechos reservados
      </p>
    </div>
  </div>

</footer>

<!-- Estilos responsive del grid de columnas -->
<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1.5fr;
    }
  }
</style>
