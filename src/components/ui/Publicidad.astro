---
// src/components/ui/Publicidad.astro
interface Props {
  pub: {
    _id:          string
    nombre:       string
    imagenUrl?:   string
    linkDestino?: string
    posicion:     string
  }
}

const { pub } = Astro.props
const tieneImagen = !!pub?.imagenUrl
---

{tieneImagen && (
  <div class="pub-wrapper">

    <!-- Imagen con o sin link -->
    {pub.linkDestino ? (
      <a
        href={pub.linkDestino}
        target="_blank"
        rel="noopener noreferrer sponsored"
        aria-label={`Publicidad: ${pub.nombre}`}
        class="pub-link"
      >
        <img
          src={pub.imagenUrl}
          alt={pub.nombre}
          loading="lazy"
          class="pub-img"
        />
      </a>
    ) : (
      <img
        src={pub.imagenUrl}
        alt={pub.nombre}
        loading="lazy"
        class="pub-img"
      />
    )}

  </div>
)}

<style>
  .pub-wrapper {
    width: 100%;
    display: block;
  }

  .pub-link {
    display: block;
    width: 100%;
  }

  .pub-img {
    width: 100%;
    display: block;
    object-fit: contain;
    border: 1px solid var(--color-borde);
    background-color: #fff;
    transition: opacity 0.2s ease;
  }

  .pub-link:hover .pub-img {
    opacity: 0.85;
  }
</style>
