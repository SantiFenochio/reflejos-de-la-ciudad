---
// src/components/ui/Publicidad.astro
interface Props {
  pub: {
    _id:          string
    nombre:       string
    imagenUrl?:   string
    linkDestino?: string
    posicion:     string
  }
}

const { pub } = Astro.props
const tieneImagen = !!pub?.imagenUrl

// El asset id de Sanity codifica dimensiones: `...-{W}x{H}.{ext}`.
// Las sacamos para poder setear width/height en el <img> y evitar layout shift (CLS).
const dims = pub?.imagenUrl?.match(/-(\d+)x(\d+)\.[a-z]+/i)
const imgW = dims ? Number(dims[1]) : undefined
const imgH = dims ? Number(dims[2]) : undefined
---

{tieneImagen && (
  <div class="pub-wrapper">

    <!-- Imagen con o sin link -->
    {pub.linkDestino ? (
      <a
        href={pub.linkDestino}
        target="_blank"
        rel="noopener noreferrer sponsored"
        aria-label={`Publicidad: ${pub.nombre}`}
        class="pub-link"
      >
        <img
          src={pub.imagenUrl}
          alt={pub.nombre}
          width={imgW}
          height={imgH}
          loading="lazy"
          decoding="async"
          class="pub-img"
        />
      </a>
    ) : (
      <img
        src={pub.imagenUrl}
        alt={pub.nombre}
        width={imgW}
        height={imgH}
        loading="lazy"
        decoding="async"
        class="pub-img"
      />
    )}

  </div>
)}

<style>
  .pub-wrapper {
    width: 100%;
    display: block;
  }

  .pub-link {
    display: block;
    width: 100%;
  }

  .pub-img {
    width: 100%;
    display: block;
    /* contain: muestra la imagen completa sin recortar (importante para flyers verticales) */
    object-fit: contain;
    /* max-height evita que flyers muy verticales rompan el layout */
    max-height: 320px;
    border: 1px solid var(--color-borde);
    background-color: var(--color-card, #FDFCF9);
    transition: opacity 0.2s ease;
  }

  .pub-link:hover .pub-img {
    opacity: 0.85;
  }
</style>
