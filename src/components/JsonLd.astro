---
// src/components/JsonLd.astro
// Genera structured data (Schema.org) en JSON-LD para distintas plantillas.
// Tipos soportados:
//   - WebSite + NewsMediaOrganization (toda página)
//   - NewsArticle (notas individuales)
//   - BreadcrumbList (notas y secciones)
//   - CollectionPage + ItemList (páginas de sección)
import { SITE_NAME, SITE_URL } from '../lib/seo';

interface WebSiteSchema     { type: 'WebSite' }
interface NewsArticleSchema {
  type:           'NewsArticle';
  headline:       string;
  description:    string;
  url:            string;
  image?:         string;
  datePublished:  string;
  dateModified?:  string;
  author:         string;
  section?:       string;
  keywords?:      string[];
  articleBody?:   string;
  wordCount?:     number;
}
interface BreadcrumbSchema  { type: 'BreadcrumbList'; items: { name: string; url: string }[] }
interface CollectionPageSchema {
  type:        'CollectionPage';
  name:        string;
  description: string;
  url:         string;
  items:       { name: string; url: string; datePublished?: string; image?: string }[];
}
type Props = WebSiteSchema | NewsArticleSchema | BreadcrumbSchema | CollectionPageSchema;

const props = Astro.props as Props;

const ORG = {
  '@type': 'NewsMediaOrganization',
  '@id': `${SITE_URL}/#organization`,
  name: SITE_NAME,
  url: SITE_URL,
  logo: { '@type': 'ImageObject', '@id': `${SITE_URL}/#logo`, url: `${SITE_URL}/Logo.png`, width: 400, height: 100, caption: SITE_NAME },
  image: { '@id': `${SITE_URL}/#logo` },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Villa Ballester',
    addressLocality: 'General San Martín',
    addressRegion: 'Buenos Aires',
    addressCountry: 'AR',
    postalCode: 'B1653',
  },
  description: 'Diario digital local de General San Martín y Villa Ballester, Buenos Aires, Argentina.',
  foundingDate: '2024',
  inLanguage: 'es-AR',
  areaServed: [
    { '@type': 'City', name: 'General San Martín', containedInPlace: { '@type': 'State', name: 'Buenos Aires' } },
    { '@type': 'City', name: 'Villa Ballester',    containedInPlace: { '@type': 'State', name: 'Buenos Aires' } },
  ],
  sameAs: [
    'https://www.instagram.com/reflejosdelaciudad',
    'https://www.facebook.com/reflejosdelaciudad',
  ],
};

function buildSchema(data: Props): object {
  switch (data.type) {
    case 'WebSite':
      return {
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'WebSite',
            '@id': `${SITE_URL}/#website`,
            url: SITE_URL,
            name: SITE_NAME,
            description: 'Diario digital local de General San Martín y Villa Ballester, Buenos Aires.',
            inLanguage: 'es-AR',
            publisher: { '@id': `${SITE_URL}/#organization` },
            potentialAction: {
              '@type': 'SearchAction',
              target: {
                '@type': 'EntryPoint',
                urlTemplate: `${SITE_URL}/?q={search_term_string}`,
              },
              'query-input': 'required name=search_term_string',
            },
          },
          ORG,
        ],
      };

    case 'NewsArticle': {
      // Imagen: usar variante OG (1200×630) si viene; fallback a logo.
      const imgUrl = data.image || `${SITE_URL}/og-default.jpg`;
      const article: Record<string, any> = {
        '@context': 'https://schema.org',
        '@type': 'NewsArticle',
        '@id': `${data.url}#article`,
        isPartOf: { '@id': `${SITE_URL}/#website` },
        headline: data.headline.slice(0, 110), // Google News recomienda ≤110 chars
        description: data.description,
        url: data.url,
        mainEntityOfPage: { '@type': 'WebPage', '@id': data.url },
        image: [
          { '@type': 'ImageObject', url: imgUrl, width: 1200, height: 630 },
        ],
        thumbnailUrl: imgUrl,
        datePublished: data.datePublished,
        dateModified: data.dateModified ?? data.datePublished,
        author: {
          '@type': 'Person',
          name: data.author,
        },
        publisher: ORG,
        inLanguage: 'es-AR',
        isAccessibleForFree: true,
        copyrightHolder: { '@id': `${SITE_URL}/#organization` },
        copyrightYear: new Date(data.datePublished).getFullYear(),
      };
      if (data.section)     article.articleSection = data.section;
      if (data.keywords && data.keywords.length > 0) {
        article.keywords = data.keywords.join(', ');
      }
      if (data.articleBody) article.articleBody    = data.articleBody;
      if (data.wordCount)   article.wordCount      = data.wordCount;
      return article;
    }

    case 'BreadcrumbList':
      return {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: data.items.map((item, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: item.name,
          item: item.url,
        })),
      };

    case 'CollectionPage':
      return {
        '@context': 'https://schema.org',
        '@type': 'CollectionPage',
        '@id': `${data.url}#collection`,
        name: data.name,
        description: data.description,
        url: data.url,
        inLanguage: 'es-AR',
        isPartOf: { '@id': `${SITE_URL}/#website` },
        publisher: { '@id': `${SITE_URL}/#organization` },
        mainEntity: {
          '@type': 'ItemList',
          numberOfItems: data.items.length,
          itemListElement: data.items.slice(0, 30).map((it, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            url: it.url,
            name: it.name,
            ...(it.image ? { image: it.image } : {}),
            ...(it.datePublished ? { datePublished: it.datePublished } : {}),
          })),
        },
      };

    default:
      return {};
  }
}

const schema = buildSchema(props);
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
